#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source "$SOURCE_DIR/functions/functions.sh"
source /etc/profile

SCRIPT_NAME=$SCRIPT_NAME

# Helper functions for HAProxy configuration management
add_lock() {
    HAPROXY_CFG_DIR=$1
    if [ -f "$HAPROXY_CFG_DIR/.haproxy.cfg.lck" ];
    then
        echo "An other process is editing haproxy.cfg. Can't edit the file."
        exit 2
    else
        touch "$HAPROXY_CFG_DIR/.haproxy.cfg.lck"
    fi
}

reload_haproxy() {
    CONTAINER_ID=$(haproxy_container_id)
    docker kill -s HUP "$CONTAINER_ID"
    echo "HAproxy reloaded"
}

remove_lock() {
    rm "$HAPROXY_CFG_DIR/.haproxy.cfg.lck"
}

OPERATION=$1
HAPROXY_CFG_DIR=/opt/haproxy/
SESSION_ID=$(od -x /dev/urandom | head -1 | awk '{OFS="-"; print $2$3,$4,$5,$6,$7$8$9}')

case $OPERATION in
    "--add")
        CASTER=$2
        CHANNEL=$3

        if [ -z "$CASTER" ];
        then
            echo "[ERROR]: Caster is missing. Try '$SCRIPT_NAME --help' for more information"
            exit 1
        fi

        if [ -z "$CHANNEL" ];
        then
            echo "[ERROR]: Channel is missing. Try '$SCRIPT_NAME --help' for more information"
            exit 1
        fi

        PORT=$(db_get_channel_port $CHANNEL)

        add_lock "$HAPROXY_CFG_DIR"

        # Extract RTMP config template from running haproxy container
        mkdir -p "/tmp/$SESSION_ID/"
        CONTAINER_ID=$(haproxy_container_id)

        if [ -z "$CONTAINER_ID" ];
        then
            remove_lock "$HAPROXY_CFG_DIR"
            echo "ERROR: HAProxy container is not running. Start it first."
            exit 1
        fi

        echo "Extracting RTMP config template from haproxy container..."
        docker exec "$CONTAINER_ID" cat /usr/local/etc/haproxy/templates/haproxy-rtmp.cfg > "/tmp/$SESSION_ID/haproxy-rtmp.cfg"

        if [ $? -ne 0 ] || [ ! -s "/tmp/$SESSION_ID/haproxy-rtmp.cfg" ];
        then
            remove_lock "$HAPROXY_CFG_DIR"
            echo "ERROR: Failed to extract RTMP template from container"
            rm -rf "/tmp/$SESSION_ID/"
            exit 1
        fi

        # Replace placeholders in template
        sed -i "s/<CHANNEL>/$CHANNEL/g" "/tmp/$SESSION_ID/haproxy-rtmp.cfg"
        sed -i "s/<CASTER>/$CASTER/g" "/tmp/$SESSION_ID/haproxy-rtmp.cfg"
        sed -i "s/<PORT>/$PORT/g" "/tmp/$SESSION_ID/haproxy-rtmp.cfg"

        # Append to main config
        echo "# ::$CASTER::start" >> "$HAPROXY_CFG_DIR/haproxy.cfg"
        cat "/tmp/$SESSION_ID/haproxy-rtmp.cfg" >> "$HAPROXY_CFG_DIR/haproxy.cfg"
        echo "# ::$CASTER::end" >> "$HAPROXY_CFG_DIR/haproxy.cfg"

        rm -rf "/tmp/$SESSION_ID/"

        remove_lock "$HAPROXY_CFG_DIR"

        reload_haproxy

    ;;
    "--remove")
        CASTER=$2

        if [ -z "$CASTER" ];
        then
            echo "[ERROR]: Caster is missing. Try '$SCRIPT_NAME --help' for more information"
            exit 1
        fi

        add_lock "$HAPROXY_CFG_DIR"

        md5old=$(md5sum "$HAPROXY_CFG_DIR/haproxy.cfg")

        sed -i "/^# ::$CASTER::start$/,/^# ::$CASTER::end$/d" "$HAPROXY_CFG_DIR/haproxy.cfg"

        md5new=$(md5sum "$HAPROXY_CFG_DIR/haproxy.cfg")

        if [ "$md5old" != "$md5new" ];
        then
            reload_haproxy
        else
            echo "No changes were made to haproxy.cfg as there was nothing to remove."
        fi

        remove_lock "$HAPROXY_CFG_DIR"

    ;;
    "--help")
        echo "$SCRIPT_NAME -- Manage HAProxy RTMP routing configuration

DESCRIPTION:
  Dynamically add or remove RTMP container routing entries in HAProxy configuration.
  Automatically performs graceful reload (HUP signal) after changes, which does NOT
  interrupt active streams.

  This script is usually called automatically by containermod when starting/stopping
  nginx-rtmp containers.

USAGE:
  $SCRIPT_NAME <operation> <parameters>

OPERATIONS:

  --add <caster> <channel>
    Add a new RTMP routing configuration for a caster's container.

    Creates HAProxy frontend/backend configuration block:
      - Frontend binds to channel's assigned port
      - Backend routes to nginx-rtmp-<caster> container on port 1935
      - Configuration wrapped in # ::<caster>::start and # ::<caster>::end markers

    Parameters:
      - caster:  Caster nickname (e.g., JohnDoe)
      - channel: Channel name (e.g., mainchannel, only1-proxy)

    Usage: $SCRIPT_NAME --add JohnDoe mainchannel
    Usage: $SCRIPT_NAME --add JohnDoe only1-proxy

  --remove <caster>
    Remove an existing RTMP routing configuration for a caster.

    Removes the configuration block between # ::<caster>::start and # ::<caster>::end
    markers from /opt/haproxy/haproxy.cfg

    Parameters:
      - caster: Caster nickname (e.g., JohnDoe)

    Usage: $SCRIPT_NAME --remove JohnDoe

CONFIGURATION DETAILS:

  Template Location:
    /usr/local/etc/haproxy/templates/haproxy-rtmp.cfg (inside haproxy container)

  Generated Config Example:
    # ::JohnDoe::start
    frontend rtmp-mainchannel
        bind *:48001
        mode tcp
        default_backend JohnDoe

    backend JohnDoe
        server nginx-rtmp-JohnDoe nginx-rtmp-JohnDoe:1935 check
    # ::JohnDoe::end

  File Locking:
    Uses /opt/haproxy/.haproxy.cfg.lck to prevent concurrent modifications

  Reload Mechanism:
    docker kill -s HUP haproxy (graceful reload, no stream interruption)

EXAMPLES:

  # Add routing for regular stream container
  haproxy_configmod --add JohnDoe mainchannel

  # Add routing for proxy container
  haproxy_configmod --add AliceSmith only1-proxy

  # Remove routing when container stops
  haproxy_configmod --remove JohnDoe

  # Manually check configuration
  cat /opt/haproxy/haproxy.cfg | grep -A 6 "::JohnDoe::"

TROUBLESHOOTING:

  If config has duplicate or broken entries:
    1. Edit /opt/haproxy/haproxy.cfg manually
    2. Remove broken/duplicate ::caster:: blocks
    3. Reload: docker kill -s HUP haproxy

  If lock file prevents edits:
    rm /opt/haproxy/.haproxy.cfg.lck

  Common Issues:
    - Multiple ::start/::end blocks for same caster (duplicate adds)
    - Orphaned blocks (container removed but config not cleaned up)
    - Missing end marker (incomplete block)

NOTES:
  - Usually called automatically by containermod --start/--stop
  - Lock file ensures only one modification at a time
  - Graceful reload preserves existing connections
  - Config changes are immediate after reload (no restart needed)
  - Port assignment comes from channels table in database
"
        exit 0
    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$SCRIPT_NAME --help' for more information"
        exit 1
    ;;
esac
