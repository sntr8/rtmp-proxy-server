#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source $SOURCE_DIR/functions/functions.sh
source /etc/profile

OPERATION=$1
REGEXP='^([0-2][0-9]|3[0-1])\.(0[1-9]|1[0-2])\.202[1-9]\s([01]?[0-9]|2[0-3]):[0-5][0-9]$'

if [ -z "$OPERATION" ];
then
    echo "$(basename "$0"): try '$(basename "$0") --help' for more information"
    exit 1
fi

CONTAINER_ID=$(docker ps -aqf "name=mysql")

case $OPERATION in
    "--add")
        echo "Available casters: "
        castermod --list --ids
        read -r -p "What's the caster ID (Use the list above): " CASTER

        if ! db_get_caster_name_with_id $CASTER > /dev/null;
        then
            echo "$CASTER is not a valid caster ID"
            exit 1
        fi

        COCASTER=""

        read -r -p "Is there a co-caster who needs a proxy container? [y/N] " RESPONSE
        case "$RESPONSE" in
            [yY][eE][sS]|[yY])
              castermod --list --ids
              read -r -p "What's the co-caster ID (Use the list above): " COCASTER
            ;;
            *)
                echo "Won't add a co-caster proxy"
            ;;
        esac

        echo "Available channels: "
        channelmod --list --ids
        read -r -p "What's the channel ID (Use the list above): " CHANNEL

        if ! db_get_channel_name_with_id $CHANNEL > /dev/null;
        then
            echo "$CHANNEL is not a valid channel ID"
            exit 1
        fi

        echo "Available games: "
        gamemod --list --ids
        read -r -p "What's the game ID? (Use the list above):  " GAME

        if ! db_get_game_name_with_id $GAME > /dev/null;
        then
            echo "$GAME is not a valid game ID"
            exit 1
        fi

        read -r -p "Twitch title for the stream?: " TITLE
        read -r -p "Start time of the stream? (Format: DD.MM.YYYY HH:MM): " START_TIME

        if ! [[ "$START_TIME" =~ $REGEXP ]];
        then
            echo "Start time is not in a valid format"
            exit 1
        fi

        if ! db_is_channel_free "$START_TIME" $CHANNEL;
        then
            echo "ERROR: The requested channel is occupied at the requested time. Can't schedule a stream."
            exit 1
        fi

        echo "Container will be started 30 minutes before the stream, if possible."

        read -r -p "End time of the stream? (Format: DD.MM.YYYY HH:MM): " END_TIME

        if ! [[ "$END_TIME" =~ $REGEXP ]];
        then
            echo "Start time is not in a valid format"
            exit 1
        fi

        if ! db_is_channel_free "$END_TIME" $CHANNEL;
        then
            echo "ERROR: The requested channel is occupied at the requested time. Can't schedule a stream."
            exit 1
        fi

        if ! db_stream_collides_with_another "$CHANNEL" "$START_TIME" "$END_TIME";
        then
            echo "ERROR: The requested channel is already occupied during the requested timespan. Can't schedule a stream."
            exit 1
        fi

        echo "Container will be stopped 30 minutes after the stream, if possible."

        printf "\n\n"

        echo "Creating a stream with details:
    Caster: $(db_get_caster_name_with_id $CASTER)
    Channel: $(db_get_channel_name_with_id $CHANNEL)
    Game: $(db_get_game_name_with_id $GAME)
    Twitch title: $TITLE
    Start time: $START_TIME
    End time: $END_TIME"
        if [ ! -z $COCASTER ];
        then
            echo "    Also adding proxy container for co-caster: $(db_get_caster_name_with_id $COCASTER)"
        fi

        printf "\n"

        read -r -p "Are you sure you want to create a new stream with above details? [y/N] " RESPONSE
        case "$RESPONSE" in
            [yY][eE][sS]|[yY])
                if [ ! -z $COCASTER ];
                then
                  docker exec mysql mysql --defaults-extra-file=/creds.cnf -e "INSERT INTO streams (\`caster_id\`, \`cocaster_id\`, \`channel_id\`, \`game_id\`, \`title\`, \`live\`, \`skip\`, \`start_time\`, \`end_time\`) VALUES ($CASTER, $COCASTER, $CHANNEL, $GAME, '$TITLE', false, false, STR_TO_DATE('$START_TIME','%d.%m.%Y %T'), STR_TO_DATE('$END_TIME','%d.%m.%Y %T'))"
                else
                  docker exec mysql mysql --defaults-extra-file=/creds.cnf -e "INSERT INTO streams (\`caster_id\`, \`channel_id\`, \`game_id\`, \`title\`, \`live\`, \`skip\`, \`start_time\`, \`end_time\`) VALUES ($CASTER, $CHANNEL, $GAME, '$TITLE', false, false, STR_TO_DATE('$START_TIME','%d.%m.%Y %T'), STR_TO_DATE('$END_TIME','%d.%m.%Y %T'))"
                fi
                if [ $? -eq 0 ];
                then
                    exit 0
                else
                    echo "An error occured while adding the stream. Possible reasons:
    - streams_et_chk: The stream end time was before the start time."
                    exit 1
                fi
            ;;
            *)
                exit 1
            ;;
        esac
    ;;
    "--add-proxy")
        echo "Available casters: "
        castermod --list --ids
        read -r -p "What's the caster ID (Use the list above): " CASTER

        if ! db_get_caster_name_with_id $CASTER > /dev/null;
        then
            echo "$CASTER is not a valid caster ID"
            exit 1
        fi

        read -r -p "Start time of the stream? (Format: DD.MM.YYYY HH:MM): " START_TIME

        if ! [[ "$START_TIME" =~ $REGEXP ]];
        then
            echo "Start time is not in a valid format"
            exit 1
        fi

        echo "Container will be started 30 minutes before the stream, if possible."

        read -r -p "End time of the stream? (Format: DD.MM.YYYY HH:MM): " END_TIME

        if ! [[ "$END_TIME" =~ $REGEXP ]];
        then
            echo "Start time is not in a valid format"
            exit 1
        fi

        echo "Container will be stopped 30 minutes after the stream, if possible."

        PROXY_COUNT=$(db_get_proxychannel_count)
        PROXY_CHANNEL=""
        for (( i=1; i <= PROXY_COUNT; i++ ))
        do
          I_CHANNEL_ID=$(channelmod --get-id "only$i-proxy")
          if db_is_channel_free "$START_TIME" $I_CHANNEL_ID;
          then
            if db_is_channel_free "$END_TIME" $I_CHANNEL_ID;
            then
              PROXY_CHANNEL_ID=$I_CHANNEL_ID
              break
            fi
          fi
        done

        if [ ! -z $PROXY_CHANNEL ];
        then
          echo "No proxy channel was free for the stream. Can't schedule one"
          exit 1
        fi

        printf "\n\n"

        echo "Creating a proxy server with details:
    Caster: $(db_get_caster_name_with_id $CASTER)
    Channel: $(db_get_channel_name_with_id $PROXY_CHANNEL_ID)
    Start time: $START_TIME
    End time: $END_TIME
        "

        read -r -p "Are you sure you want to create a proxy server with above details? [y/N] " RESPONSE
        case "$RESPONSE" in
            [yY][eE][sS]|[yY])
                docker exec mysql mysql --defaults-extra-file=/creds.cnf -e "INSERT INTO streams (\`caster_id\`, \`channel_id\`, \`live\`, \`skip\`, \`start_time\`, \`end_time\`) VALUES ($CASTER, $PROXY_CHANNEL_ID, false, false, STR_TO_DATE('$START_TIME','%d.%m.%Y %T'), STR_TO_DATE('$END_TIME','%d.%m.%Y %T'))"
                if [ $? -eq 0 ];
                then
                    exit 0
                else
                    echo "An error occured while adding the stream. Possible reasons:
    - streams_et_chk: The stream end time was before the start time."
                    exit 1
                fi
            ;;
            *)
                exit 1
            ;;
        esac
    ;;
    "--live")
        OPTION=$2
        if [ -z $OPTION ];
        then
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT s.id, ca.nick as caster, ch.name as channel, g.name as game, s.start_time, s.end_time FROM casters ca, channels ch, games g, streams s WHERE s.caster_id = ca.id AND s.channel_id = ch.id AND s.game_id = g.id AND s.live = true"
            exit 0
        else
            case $OPTION in
                "--ids")
                    docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT id FROM streams WHERE live = true"
                    exit 0
                ;;
            esac
        fi
    ;;
    "--upcoming")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Upcoming streams: "
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT s.id, ca.nick as caster, (SELECT IFNULL(cc.nick, \"Not set\") FROM casters cc, streams st WHERE cc.id = st.cocaster_id AND st.id = s.id) as cocaster, ch.name as channel, g.name as game, s.start_time, s.end_time FROM casters ca, channels ch, games g, streams s WHERE s.caster_id = ca.id AND s.channel_id = ch.id AND s.game_id = g.id AND ch.access_token IS NOT NULL and start_time >= NOW() ORDER BY start_time"
            echo "Upcoming proxies"
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT s.id, ca.nick as caster, ch.name as channel, s.start_time, s.end_time FROM casters ca, channels ch, streams s WHERE s.caster_id = ca.id AND s.channel_id = ch.id AND ch.name LIKE '%-proxy' AND start_time >= NOW() AND ch.access_token IS NULL ORDER BY start_time"
            exit 0
        else
            case $OPTION in
                "--ids")
                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT id FROM streams WHERE start_time >= NOW()"
                    exit 0
                ;;
            esac
        fi
    ;;
    "--update")
        STREAM_ID=$2
        if [ -z $STREAM_ID ];
        then
            echo "Stream id was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        if ! db_stream_exists $STREAM_ID;
        then
            echo "Stream does not exists with id $STREAM_ID"
            exit 1
        fi

        CASTER_NAME=$(db_get_caster_with_stream_id $STREAM_ID)
        CHANNEL_NAME=$(db_get_channel_with_stream_id $STREAM_ID)
        COCASTER=$(db_get_cocaster_name_with_stream_id $STREAM_ID)
        TITLE=$(db_get_stream_title $STREAM_ID)
        START_TIME=$(db_get_stream_start_time $STREAM_ID)
        END_TIME=$(db_get_stream_end_time $STREAM_ID)

        echo "Stream caster is: $CASTER_NAME"
        read -r -p "Want to edit the caster? [y/N] " RESPONSE_CASTER
        case "$RESPONSE_CASTER" in
            [yY][eE][sS]|[yY])
                echo "Available casters: "
                castermod --list --ids
                read -r -p "What's the caster ID (Use the list above): " EDIT_CASTER

                if ! db_get_caster_name_with_id $EDIT_CASTER > /dev/null;
                then
                    echo "$EDIT_CASTER is not a valid caster ID"
                    exit 1
                fi

                docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET caster_id = $EDIT_CASTER WHERE id = $STREAM_ID"
                echo "Updated to the database"
            ;;
        esac

        printf "\n"

        echo "Stream channel is: $CHANNEL_NAME"
        read -r -p "Want to edit the channel? [y/N] " RESPONSE_CHANNEL

        case "$RESPONSE_CHANNEL" in
            [yY][eE][sS]|[yY])
                echo "Available channels: "
                channelmod --list --ids
                read -r -p "What's the channel ID (Use the list above): " EDIT_CHANNEL

                if ! db_get_channel_name_with_id $EDIT_CHANNEL > /dev/null;
                then
                    echo "$EDIT_CHANNEL is not a valid channel ID"
                    exit 1
                fi

                docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET channel_id = $EDIT_CHANNEL WHERE id = $STREAM_ID"
                echo "Updated to the database"
            ;;
        esac

        printf "\n"

        if [ ! -z $COCASTER ];
        then
            echo "Stream has a co-caster container for: $COCASTER"
            read -r -p "Want to change the co-caster container?
Edit: e
Delete: d
No changes: N
[e/d/N]: " RESPONSE_COCASTER

            case "$RESPONSE_COCASTER" in
                [eE][dD][iI][tT]|[e])
                    echo "Available co-casters: "
                    castermod --list --ids
                    read -r -p "What's the co-caster ID (Use the list above): " EDIT_COCASTER

                    if ! db_get_caster_name_with_id $EDIT_CASTER > /dev/null;
                    then
                        echo "$EDIT_CASTER is not a valid caster ID"
                        exit 1
                    fi

                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET cocaster_id = $EDIT_COCASTER WHERE id = $STREAM_ID"
                    echo "Updated to the database"
                ;;
                [dD][eE][lL][eE][tT][eE]|[d])
                    read -r -p "Confirm delete co-caster container from the stream? [y/N] " RESPONSE_CC_CONFIRM
                    case "$RESPONSE_CC_CONFIRM" in
                        [yY][eE][sS]|[yY])
                            docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET cocaster_id = null WHERE id = $STREAM_ID"
                            echo "Updated to the database"
                        ;;
                    esac
                ;;
            esac
        else
            read -r -p "Stream has no co-caster container set. Want to add one? [y/N] " RESPONSE_COCASTER_ADD
            case "$RESPONSE_COCASTER_ADD" in
                [yY][eE][sS]|[yY])
                    echo "Available co-casters: "
                    castermod --list --ids
                    read -r -p "What's the co-caster ID (Use the list above): " EDIT_COCASTER

                    if ! db_get_caster_name_with_id $EDIT_COCASTER > /dev/null;
                    then
                        echo "$EDIT_COCASTER is not a valid caster ID"
                        exit 1
                    fi

                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET cocaster_id = $EDIT_COCASTER WHERE id = $STREAM_ID"
                    echo "Updated to the database"
                ;;
            esac
        fi

        printf "\n"

        echo "Stream title is: $TITLE"
        read -r -p "Want to edit the title? [y/N] " RESPONSE_TITLE

        case "$RESPONSE_TITLE" in
            [yY][eE][sS]|[yY])
                read -r -p "Twitch title for the stream?: " EDIT_TITLE

                docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET title = '$EDIT_TITLE' WHERE id = $STREAM_ID"
                echo "Updated to the database"
            ;;
        esac

        printf "\n"

        echo "Stream start time is: $START_TIME"
        read -r -p "Want to edit the start time? [y/N] " RESPONSE_START

        case "$RESPONSE_START" in
            [yY][eE][sS]|[yY])
                read -r -p "Start time of the stream? (Format: DD.MM.YYYY HH:MM): " EDIT_START_TIME

                if ! [[ "$EDIT_START_TIME" =~ $REGEXP ]];
                then
                    echo "Time is not in a valid format"
                    exit 1
                fi

                if ! db_is_channel_free "$EDIT_START_TIME" $(channelmod --get-id $CHANNEL_NAME) $STREAM_ID;
                then
                  echo "ERROR: The requested channel is occupied at the requested time. Can't schedule a stream."
                  exit 1
                fi

                if ! db_stream_collides_with_another "$(channelmod --get-id $CHANNEL_NAME)" "$EDIT_START_TIME" "$END_TIME" $STREAM_ID;
                then
                    echo "ERROR: The requested channel is already occupied during the requested timespan. Can't schedule a stream."
                    exit 1
                fi

                START_TIME="$EDIT_START_TIME"

                docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET start_time = STR_TO_DATE('$EDIT_START_TIME','%d.%m.%Y %T') WHERE id = $STREAM_ID"
                echo "Updated to the database"
            ;;
        esac

        printf "\n"

        echo "Stream end time is: $END_TIME"
        read -r -p "Want to edit the start time? [y/N] " RESPONSE_END

        case "$RESPONSE_END" in
            [yY][eE][sS]|[yY])
                read -r -p "End time of the stream? (Format: DD.MM.YYYY HH:MM): " EDIT_END_TIME

                if ! [[ "$EDIT_END_TIME" =~ $REGEXP ]];
                then
                    echo "Time is not in a valid format"
                    exit 1
                fi

                if ! db_is_channel_free "$EDIT_END_TIME" $(channelmod --get-id $CHANNEL_NAME) $STREAM_ID;
                then
                  echo "ERROR: The requested channel is occupied at the requested time. Can't schedule a stream."
                  exit 1
                fi

                if ! db_stream_collides_with_another "$(channelmod --get-id $CHANNEL_NAME)" "$START_TIME" "$EDIT_END_TIME" $STREAM_ID;
                then
                    echo "ERROR: The requested channel is already occupied during the requested timespan. Can't schedule a stream."
                    exit 1
                fi

                docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET end_time = STR_TO_DATE('$EDIT_END_TIME','%d.%m.%Y %T') WHERE id = $STREAM_ID"
                echo "Updated to the database"
            ;;
        esac

        echo "No further details to edit"
        exit 0
    ;;
    "--set")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "No option was provided. Try '$(basename "$0") --help' for more information."
            exit 1
        else
            ID=$3
            if [ -z $ID ];
            then
                echo "No Stream ID was provided. Try '$(basename "$0") --help' for more information."
                exit 1
            fi

            case $OPTION in
                "live")
                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "UPDATE streams SET live = true WHERE id = $ID"
                    exit 0
                ;;
                "nonlive")
                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "UPDATE streams SET live = false WHERE id = $ID"
                    exit 0
                ;;
            esac
        fi
    ;;
    "--starting")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Starting streams:"
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT s.id, ca.nick as caster, ch.name as channel, g.name as game, s.start_time, s.end_time FROM casters ca, channels ch, games g, streams s WHERE s.caster_id = ca.id AND s.channel_id = ch.id AND s.game_id = g.id AND start_time BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 MINUTE) ORDER BY start_time"
            echo "Starting proxies:"
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT s.id, ca.nick as caster, ch.name as channel, s.start_time, s.end_time FROM casters ca, channels ch, streams s WHERE s.caster_id = ca.id AND s.channel_id = ch.id AND start_time BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 MINUTE) ORDER BY start_time"
            exit 0
        else
            case $OPTION in
                "--ids")
                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT id FROM streams WHERE start_time BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 MINUTE) AND skip = false"
                    exit 0
                ;;
                *)
                    echo "Option not recognised. Try '$(basename "$0") --help' for more information."
                    exit 1
                ;;
            esac
        fi
    ;;
    "--ending")
        OPTION=$2
        if [ -z $OPTION ];
        then
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT s.id, ca.nick as caster, ch.name as channel, g.name as game, s.start_time, s.end_time FROM casters ca, channels ch, games g, streams s WHERE s.caster_id = ca.id AND s.channel_id = ch.id AND s.game_id = g.id AND end_time BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 MINUTE) ORDER BY end_time"
            exit 0
        else
            case $OPTION in
                "--ids")
                    docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT id FROM streams WHERE end_time BETWEEN DATE_SUB(NOW(), INTERVAL 30 MINUTE) AND DATE_ADD(NOW(), INTERVAL 30 MINUTE)"
                    exit 0
                ;;
                *)
                    echo "Option not recognised. Try '$(basename "$0") --help' for more information."
                    exit 1
                ;;
            esac
        fi
    ;;
    "--warnings")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Warning time not set. Try '$(basename "$0") --help' for more information."
            exit 1
        else
            docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT id FROM streams WHERE DATE_FORMAT(DATE_ADD(NOW(), INTERVAL $OPTION MINUTE), '%d.%m.%Y %H:%i') = DATE_FORMAT(end_time, '%d.%m.%Y %H:%i')"
            exit 0
        fi
    ;;
    "--ended")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Warning time not set. Try '$(basename "$0") --help' for more information."
            exit 1
        else
            docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT id FROM streams WHERE DATE_FORMAT(DATE_SUB(NOW(), INTERVAL $OPTION MINUTE), '%d.%m.%Y %H:%i') = DATE_FORMAT(end_time, '%d.%m.%Y %H:%i')"
            exit 0
        fi
    ;;
    "--extend")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Stream id was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET end_time = DATE_ADD(end_time, INTERVAL 30 MINUTE) WHERE id = '$OPTION'"
    ;;
    "--skip")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Stream id was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET skip = true WHERE id = '$OPTION'"
    ;;
    "--unskip")
        OPTION=$2
        if [ -z $OPTION ];
        then
            echo "Stream id was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "UPDATE streams SET skip = false WHERE id = '$OPTION'"
    ;;
    "--help")
        echo "$(basename "$0") -- Schedule and manage RTMP streams

DESCRIPTION:
  Manages scheduled streams in the database. Streams should always be scheduled
  in advance to enable automatic container startup/shutdown and Discord notifications.

USAGE:
  $(basename "$0") <operation> [options]

USER OPERATIONS:

  --add
    Interactive tool to schedule a new stream. Prompts for:
    - Caster ID (from castermod --list --ids)
    - Co-caster ID (optional, for proxy container)
    - Channel ID (from channelmod --list --ids)
    - Game ID (from gamemod --list --ids)
    - Twitch title
    - Start time (format: DD.MM.YYYY HH:MM)
    - End time (format: DD.MM.YYYY HH:MM)

    Usage: $(basename "$0") --add

    Note: Containers start 30 min before and stop 30 min after scheduled time.

  --add-proxy
    Interactive tool to schedule a proxy-only container (no Twitch stream).
    Automatically selects an available proxy channel (only1-proxy through only6-proxy).

    Usage: $(basename "$0") --add-proxy

  --upcoming
    List all scheduled future streams (both regular and proxy).

    Usage: $(basename "$0") --upcoming
    Usage: $(basename "$0") --upcoming --ids    (returns only IDs)

  --live
    List currently live streams.

    Usage: $(basename "$0") --live
    Usage: $(basename "$0") --live --ids        (returns only IDs)

  --ending
    List streams ending within 30 minutes.

    Usage: $(basename "$0") --ending
    Usage: $(basename "$0") --ending --ids      (returns only IDs)

  --extend <stream_id>
    Extend a stream's end time by 30 minutes.

    Usage: $(basename "$0") --extend 42

    Parameters:
      - stream_id: ID of the stream to extend

  --update <stream_id>
    Interactive tool to update an existing scheduled stream.
    Allows editing caster, channel, game, title, start time, and end time.

    Usage: $(basename "$0") --update 42

  --skip <stream_id>
    Mark a stream to be skipped (container won't start automatically).
    Use when a scheduled stream needs to be canceled but kept in database.

    Usage: $(basename "$0") --skip 42

  --unskip <stream_id>
    Remove skip flag from a stream (re-enable automatic startup).

    Usage: $(basename "$0") --unskip 42

  --delete <stream_id>
    Delete a stream from the database.

    Usage: $(basename "$0") --delete 42

INTERNAL OPERATIONS (used by cron_worker.sh):

  --starting [--ids]
    List streams starting within 30 minutes.

  --ended <minutes>
    List streams that ended <minutes> ago and still have containers running.

  --warnings <minutes>
    List streams ending in exactly <minutes> (for notifications).

  --set live|nonlive <stream_id>
    Mark a stream as live or not live.

EXAMPLES:

  # Schedule a new stream interactively
  streammod --add

  # List upcoming streams
  streammod --upcoming

  # Extend a stream that's running longer than expected
  streammod --extend 42

  # Cancel a scheduled stream (marks it to skip)
  streammod --skip 42

  # Update stream details
  streammod --update 42

NOTES:
  - Always schedule streams in advance for automatic container management
  - Stream collisions are NOT automatically checked - verify manually with --upcoming
  - Time format must be DD.MM.YYYY HH:MM (e.g., 15.03.2026 19:30)
  - Containers start 30 minutes before and stop 30 minutes after scheduled times
"
    exit 0

    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$(basename "$0") --help' for more information"
        exit 1
    ;;
esac
