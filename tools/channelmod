#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source $SOURCE_DIR/functions/functions.sh
source /etc/profile

OPERATION=$1
require_operation "$OPERATION"

case $OPERATION in
    "--list")
        OPTION=$2

        if [ -z "$OPTION" ];
        then
            echo "Available channels:"
            mysql_exec_silent "SELECT name FROM channels WHERE access_token IS NOT NULL ORDER by name"
            exit 0
        fi

        case $OPTION in
            "--ids")
                mysql_exec_interactive "SELECT id, name FROM channels WHERE access_token IS NOT NULL AND name != 'proxy-only' ORDER BY id"
                exit 0
            ;;
            *)
                echo "Option $OPTION not recognised. Try '$(basename "$0") --help' for more information."
            ;;
        esac
    ;;
    "--get-id")
        CHANNEL_NAME="$2"

        if [ -z "$CHANNEL_NAME" ];
        then
            echo "Channel name was not provided"
            exit 1
        fi

        mysql_exec_silent "SELECT id FROM channels WHERE name = '$CHANNEL_NAME'"
        exit 0
    ;;
    "--refresh-tokens")
        CHANNEL=$2

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        if ! search_channel "$CHANNEL";
        then
            exit 1
        fi

        twitch_refresh_tokens $CHANNEL;

        if [ $? -eq 0 ];
        then
            exit 0
        else
            exit 1
        fi
    ;;
    "--set")
        CHANNEL=$2
        KEY=$3
        VALUE=$4

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        if ! search_channel "$CHANNEL";
        then
            exit 1
        fi

        if [ -z "$KEY" ];
        then
            echo "Key-value pair was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        if [ -z "$VALUE" ];
        then
            echo "Key-value pair was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        case $KEY in
            "access_token")
                if mysql_exec "UPDATE channels SET access_token = '$VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Access token updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Access token change failed"
                fi
            ;;
            "client_id")
                if mysql_exec "UPDATE channels SET client_id = '$VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Client ID updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Client ID change failed"
                fi
            ;;
            "refresh_token")
                if mysql_exec "UPDATE channels SET refresh_token = '$VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Refresh token updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Refresh token change failed"
                fi
            ;;
            *)
                echo "Key not recognised. Allowed values are: access_token, client_id and refresh_token"
                exit 1
            ;;
        esac
    ;;
    "--test-tokens")
        CHANNEL=$2

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        if ! search_channel "$CHANNEL";
        then
            exit 1
        fi

        twitch_check_accees_token $CHANNEL

        if [ $? -eq 0 ];
        then
            echo "Tokens are valid for $CHANNEL"
            exit 0
        else
            echo "ERROR: Tokens did not validate for $CHANNEL"
            exit 1
        fi
    ;;
    "--get")
        CHANNEL=$2
        KEY=$3

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        if ! search_channel "$CHANNEL";
        then
            exit 1
        fi

        if [ -z "$KEY" ];
        then
            echo "Key was not given. Try '$(basename "$0") --help' for more information."
            exit 1
        fi

        case $KEY in
            "refresh_token")
                mysql_exec_silent "SELECT refresh_token FROM channels WHERE name = '$CHANNEL'"
                exit 0
            ;;
            *)
                echo "Key not recognised. Allowed values are: refresh_token"
                exit 1
            ;;
        esac
    ;;
    "--help")
        echo "$(basename "$0") -- Manage Twitch channels and API tokens

DESCRIPTION:
  Manage Twitch channel configurations, including API tokens for stream key fetching
  and channel information updates. Handles both regular Twitch channels and internal
  proxy channels.

USAGE:
  $(basename "$0") <operation> [parameters]

OPERATIONS:

  --list [option]
    List available channels in the database.

    Usage: $(basename "$0") --list            (show Twitch channel names)
    Usage: $(basename "$0") --list --ids      (show IDs and names)

    Note: Only lists channels with access_token (excludes proxy-only channels)

  --get-id <channel_name>
    Get the database ID for a specific channel.

    Usage: $(basename "$0") --get-id yourchannel

    Returns: Channel ID number

  --get <channel> <key>
    Fetch a specific value from the database for a channel.

    Parameters:
      - channel: Channel name (e.g., yourchannel)
      - key:     Database field name (currently only 'refresh_token' supported)

    Usage: $(basename "$0") --get yourchannel refresh_token

  --set <channel> <key> <value>
    Update a specific value in the database for a channel.

    Parameters:
      - channel: Channel name (e.g., yourchannel)
      - key:     Field to update (access_token, client_id, or refresh_token)
      - value:   New value for the field

    Usage: $(basename "$0") --set yourchannel access_token abc123xyz789
    Usage: $(basename "$0") --set yourchannel client_id gp762nuuoqcoxypju8c569th9wz7q5
    Usage: $(basename "$0") --set yourchannel refresh_token def456uvw012

  --refresh-tokens <channel>
    Manually trigger Twitch token refresh using twitchtokengenerator.com API.
    Uses the channel's refresh_token to obtain a new access_token.

    Usage: $(basename "$0") --refresh-tokens yourchannel

    Note: Tokens expire after 60 days. System attempts auto-refresh when needed.

  --test-tokens <channel>
    Validate that a channel's Twitch API tokens are currently valid.

    Usage: $(basename "$0") --test-tokens yourchannel

    Returns: Exit 0 if valid, exit 1 if invalid

EXAMPLES:

  # List all Twitch channels
  channelmod --list

  # Get channel ID for use in other commands
  channelmod --get-id yourchannel

  # Check if tokens are valid
  channelmod --test-tokens yourchannel

  # Manually refresh expired tokens
  channelmod --refresh-tokens yourchannel

  # Update access token after manual fetch from twitchtokengenerator.com
  channelmod --set yourchannel access_token new_token_here
  channelmod --set yourchannel refresh_token new_refresh_token_here
  channelmod --set yourchannel client_id new_client_id_here

  # Get current refresh token
  channelmod --get yourchannel refresh_token

TWITCH API TOKENS:
  Channels need three tokens from twitchtokengenerator.com:
    - access_token:  Used for Twitch Helix API calls (expires in 60 days)
    - refresh_token: Used to refresh the access_token automatically
    - client_id:     Application identifier

  When access_token expires:
    1. System automatically attempts refresh using refresh_token
    2. If auto-refresh fails, Discord notification is sent
    3. Manual update required using --set command

NOTES:
  - Proxy channels (e.g., only1-proxy) don't have Twitch tokens
  - Token validation happens automatically when containers start
  - Failed token refresh triggers Discord alerts to support group
"
        exit 0
    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$(basename "$0") --help' for more information"
        exit 1
    ;;
esac
