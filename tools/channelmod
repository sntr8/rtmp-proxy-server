#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source "$SOURCE_DIR/functions/functions.sh"
source /etc/profile

SCRIPT_NAME=$SCRIPT_NAME
OPERATION=$1
require_operation "$OPERATION"

case $OPERATION in
    "--create")
        NAME=$2
        PLATFORM=$3
        STREAM_URL=$4
        STREAM_KEY=$5

        if [ -z "$NAME" ] || [ -z "$PLATFORM" ] || [ -z "$STREAM_URL" ];
        then
            echo "Name, platform, and stream URL required. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        if ! validate_alphanumeric "$NAME";
        then
            echo "[ERROR]: Invalid channel name. Only alphanumeric characters, dash, and underscore allowed."
            exit 1
        fi

        # Validate platform
        if [[ ! "$PLATFORM" =~ ^(twitch|instagram|facebook|youtube)$ ]];
        then
            echo "Invalid platform. Allowed values are: twitch, instagram, facebook, youtube"
            exit 1
        fi

        # Check if channel already exists
        EXISTING=$(mysql_exec_silent "SELECT name FROM channels WHERE name = '$NAME'")
        if [ -n "$EXISTING" ];
        then
            echo "ERROR: Channel '$NAME' already exists"
            exit 1
        fi

        SAFE_URL=$(sanitize_sql_string "$STREAM_URL")
        SAFE_KEY=$(sanitize_sql_string "$STREAM_KEY")

        # For Twitch, try to auto-fetch stream key if not provided
        if [ "$PLATFORM" = "twitch" ] && [ -z "$STREAM_KEY" ];
        then
            echo "Stream key not provided for Twitch channel."
            echo "You can provide it later or set up API credentials for auto-fetch."
        fi

        if mysql_exec "INSERT INTO channels (name, platform, stream_url, stream_key) VALUES ('$NAME', '$PLATFORM', '$SAFE_URL', '$SAFE_KEY')";
        then
            echo "Channel '$NAME' created ($PLATFORM)"
            exit 0
        else
            echo "Failed to create channel"
            exit 1
        fi
    ;;

    "--list")
        OPTION=$2

        if [ -z "$OPTION" ];
        then
            # List all channels
            echo "Available channels:"
            mysql_exec_interactive "
                SELECT
                    name AS Channel,
                    platform AS Platform,
                    stream_url AS 'Stream URL',
                    IF(stream_key IS NOT NULL, 'set', 'not set') AS 'Stream Key',
                    display_name AS 'Display Name'
                FROM channels
                ORDER BY platform, name"
            exit 0
        fi

        case $OPTION in
            "--ids")
                mysql_exec_interactive "SELECT id, name, platform FROM channels ORDER BY id"
                exit 0
            ;;
            *)
                echo "Option $OPTION not recognised. Try '$SCRIPT_NAME --help' for more information."
            ;;
        esac
    ;;

    "--get-id")
        CHANNEL_NAME="$2"

        if [ -z "$CHANNEL_NAME" ];
        then
            echo "Channel name was not provided"
            exit 1
        fi

        if ! validate_alphanumeric "$CHANNEL_NAME";
        then
            echo "[ERROR]: Invalid channel name. Only alphanumeric characters, dash, and underscore allowed."
            exit 1
        fi

        mysql_exec_silent "SELECT id FROM channels WHERE name = '$CHANNEL_NAME'"
        exit 0
    ;;

    "--refresh-tokens")
        CHANNEL=$2

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        # Check if channel exists
        PLATFORM=$(mysql_exec_silent "SELECT platform FROM channels WHERE name = '$CHANNEL'")
        if [ -z "$PLATFORM" ];
        then
            echo "ERROR: Channel '$CHANNEL' not found"
            exit 1
        fi

        if [ "$PLATFORM" = "youtube" ];
        then
            echo "YouTube tokens are always fetched fresh (1-hour expiry)"
            echo "Testing if credentials can obtain fresh tokens..."
            if youtube_check_credentials $CHANNEL;
            then
                echo "✓ YouTube credentials are valid"
                exit 0
            else
                echo "✗ YouTube credentials are invalid"
                exit 1
            fi
        elif [ "$PLATFORM" = "twitch" ];
        then
            twitch_refresh_tokens $CHANNEL
            exit $?
        else
            echo "ERROR: Token refresh only supported for Twitch and YouTube channels"
            exit 1
        fi
    ;;

    "--set")
        CHANNEL=$2
        KEY=$3
        VALUE=$4

        if [ -z "$CHANNEL" ] || [ -z "$KEY" ] || [ -z "$VALUE" ];
        then
            echo "Channel name, key, and value required. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        # Check if channel exists
        CHANNEL_ID=$(mysql_exec_silent "SELECT id FROM channels WHERE name = '$CHANNEL'")
        if [ -z "$CHANNEL_ID" ];
        then
            echo "ERROR: Channel '$CHANNEL' not found"
            exit 1
        fi

        if ! validate_alphanumeric "$CHANNEL";
        then
            echo "[ERROR]: Invalid channel name. Only alphanumeric characters, dash, and underscore allowed."
            exit 1
        fi

        # Sanitize VALUE to prevent SQL injection
        SAFE_VALUE=$(sanitize_sql_string "$VALUE")

        case $KEY in
            "access_token")
                if mysql_exec "UPDATE channels SET access_token = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Access token updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Access token change failed"
                fi
            ;;
            "client_id")
                if mysql_exec "UPDATE channels SET client_id = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Client ID updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Client ID change failed"
                fi
            ;;
            "client_secret")
                if mysql_exec "UPDATE channels SET client_secret = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Client secret updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Client secret change failed"
                fi
            ;;
            "refresh_token")
                if mysql_exec "UPDATE channels SET refresh_token = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Refresh token updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Refresh token change failed"
                fi
            ;;
            "platform")
                # Validate platform value
                if [[ ! "$SAFE_VALUE" =~ ^(twitch|instagram|facebook|youtube)$ ]];
                then
                    echo "Invalid platform. Allowed values are: twitch, instagram, facebook, youtube"
                    exit 1
                fi
                if mysql_exec "UPDATE channels SET platform = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Platform updated to $SAFE_VALUE for channel $CHANNEL"
                    exit 0
                else
                    echo "Platform change failed"
                fi
            ;;
            "stream_url")
                if mysql_exec "UPDATE channels SET stream_url = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Stream URL updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Stream URL change failed"
                fi
            ;;
            "display_name")
                if mysql_exec "UPDATE channels SET display_name = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Display name updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Display name change failed"
                fi
            ;;
            "stream_key")
                if mysql_exec "UPDATE channels SET stream_key = '$SAFE_VALUE' WHERE name = '$CHANNEL'";
                then
                    echo "Stream key updated for channel $CHANNEL"
                    exit 0
                else
                    echo "Stream key change failed"
                fi
            ;;
            *)
                echo "Key not recognised. Allowed values are: access_token, client_id, client_secret, refresh_token, platform, stream_url, display_name, stream_key"
                exit 1
            ;;
        esac
    ;;

    "--test-tokens")
        CHANNEL=$2

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        # Check if channel exists
        PLATFORM=$(mysql_exec_silent "SELECT platform FROM channels WHERE name = '$CHANNEL'")
        if [ -z "$PLATFORM" ];
        then
            echo "ERROR: Channel '$CHANNEL' not found"
            exit 1
        fi

        if [[ "$PLATFORM" != "twitch" && "$PLATFORM" != "youtube" ]];
        then
            echo "ERROR: Token testing only supported for Twitch and YouTube channels"
            exit 1
        fi

        if validate_platform_credentials $CHANNEL;
        then
            echo "Credentials are valid for $CHANNEL ($PLATFORM)"
            exit 0
        else
            echo "ERROR: Credentials are invalid for $CHANNEL ($PLATFORM)"
            exit 1
        fi
    ;;

    "--auto-fetch-key")
        CHANNEL=$2

        if [ -z "$CHANNEL" ];
        then
            echo "Channel was not given. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        # Check if channel exists
        PLATFORM=$(mysql_exec_silent "SELECT platform FROM channels WHERE name = '$CHANNEL'")
        if [ -z "$PLATFORM" ];
        then
            echo "ERROR: Channel '$CHANNEL' not found"
            exit 1
        fi

        if [[ "$PLATFORM" != "twitch" && "$PLATFORM" != "youtube" ]];
        then
            echo "ERROR: Auto-fetch only supported for Twitch and YouTube channels"
            exit 1
        fi

        # Check if channel has API credentials
        CLIENT_ID=$(mysql_exec_silent "SELECT client_id FROM channels WHERE name = '$CHANNEL'")

        if [ "$PLATFORM" = "youtube" ];
        then
            CLIENT_SECRET=$(mysql_exec_silent "SELECT client_secret FROM channels WHERE name = '$CHANNEL'")
            REFRESH_TOKEN=$(mysql_exec_silent "SELECT refresh_token FROM channels WHERE name = '$CHANNEL'")
            if [ -z "$CLIENT_ID" ] || [ -z "$CLIENT_SECRET" ] || [ -z "$REFRESH_TOKEN" ];
            then
                echo "ERROR: Channel '$CHANNEL' is missing YouTube API credentials"
                echo "Set them first with:"
                echo "  channelmod --set $CHANNEL client_id <google_client_id>"
                echo "  channelmod --set $CHANNEL client_secret <google_client_secret>"
                echo "  channelmod --set $CHANNEL refresh_token <google_refresh_token>"
                exit 1
            fi
        elif [ "$PLATFORM" = "twitch" ];
        then
            ACCESS_TOKEN=$(mysql_exec_silent "SELECT access_token FROM channels WHERE name = '$CHANNEL'")
            if [ -z "$ACCESS_TOKEN" ] || [ -z "$CLIENT_ID" ];
            then
                echo "ERROR: Channel '$CHANNEL' is missing Twitch API credentials"
                echo "Set them first with:"
                echo "  channelmod --set $CHANNEL access_token <token>"
                echo "  channelmod --set $CHANNEL client_id <client_id>"
                echo "  channelmod --set $CHANNEL refresh_token <refresh_token>"
                exit 1
            fi
        fi

        echo "Fetching stream key from $PLATFORM API for $CHANNEL..."
        STREAM_KEY=$(get_platform_stream_key $CHANNEL)

        if [ $? -eq 0 ] && [ ! -z "$STREAM_KEY" ] && [ "$STREAM_KEY" != "null" ];
        then
            # Store the stream key
            mysql_exec_silent "UPDATE channels SET stream_key = '$STREAM_KEY' WHERE name = '$CHANNEL'"
            echo "Stream key fetched and stored successfully for $CHANNEL"
            exit 0
        else
            echo "ERROR: Failed to fetch stream key for $CHANNEL"
            echo "Make sure your $PLATFORM API credentials are valid"
            echo "Try: channelmod --test-tokens $CHANNEL"
            exit 1
        fi
    ;;

    "--get")
        CHANNEL=$2
        KEY=$3

        if [ -z "$CHANNEL" ] || [ -z "$KEY" ];
        then
            echo "Channel and key required. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        # Check if channel exists
        CHANNEL_ID=$(mysql_exec_silent "SELECT id FROM channels WHERE name = '$CHANNEL'")
        if [ -z "$CHANNEL_ID" ];
        then
            echo "ERROR: Channel '$CHANNEL' not found"
            exit 1
        fi

        case $KEY in
            "refresh_token")
                mysql_exec_silent "SELECT refresh_token FROM channels WHERE name = '$CHANNEL'"
                exit 0
            ;;
            "stream_key")
                mysql_exec_silent "SELECT stream_key FROM channels WHERE name = '$CHANNEL'"
                exit 0
            ;;
            *)
                echo "Key not recognised. Allowed values are: refresh_token, stream_key"
                exit 1
            ;;
        esac
    ;;

    "--remove")
        CHANNEL=$2

        if [ -z "$CHANNEL" ];
        then
            echo "Channel name not provided. Try '$SCRIPT_NAME --help' for more information."
            exit 1
        fi

        if ! validate_alphanumeric "$CHANNEL";
        then
            echo "[ERROR]: Invalid channel name."
            exit 1
        fi

        # Check if channel exists
        CHANNEL_ID=$(mysql_exec_silent "SELECT id FROM channels WHERE name = '$CHANNEL'")
        if [ -z "$CHANNEL_ID" ];
        then
            echo "ERROR: Channel '$CHANNEL' not found"
            exit 1
        fi

        # Check if channel is linked to any broadcasts
        LINKED_COUNT=$(mysql_exec_silent "SELECT COUNT(*) FROM broadcast_channels WHERE channel_id = $CHANNEL_ID")
        LINKED_COUNT=$(strip_cr "$LINKED_COUNT")

        if [ "$LINKED_COUNT" -gt 0 ];
        then
            echo "WARNING: Channel '$CHANNEL' is linked to $LINKED_COUNT broadcast(s)"
            echo "Removing the channel will unlink it from all broadcasts."
            read -r -p "Continue? [y/N] " RESPONSE
            case "$RESPONSE" in
                [yY][eE][sS]|[yY])
                    # Continue
                ;;
                *)
                    echo "Cancelled"
                    exit 0
                ;;
            esac
        fi

        if mysql_exec "DELETE FROM channels WHERE name = '$CHANNEL'";
        then
            echo "Channel '$CHANNEL' removed"
            exit 0
        else
            echo "Failed to remove channel"
            exit 1
        fi
    ;;

    "--help")
        echo "$SCRIPT_NAME -- Manage platform channels

DESCRIPTION:
  Channels are platform-specific streaming destinations (Twitch, Instagram, Facebook, YouTube).
  Channels are reusable and can be linked to multiple broadcasts via broadcastmod.

USAGE:
  $SCRIPT_NAME <operation> [parameters]

OPERATIONS:

  --create <name> <platform> <stream_url> [stream_key]
    Create a new platform channel.

    Parameters:
      - name:       Channel identifier (e.g., my_twitch, my_instagram)
      - platform:   twitch, instagram, facebook, or youtube
      - stream_url: Platform RTMP URL
      - stream_key: Optional stream key

    Usage: $SCRIPT_NAME --create my_twitch twitch rtmp://live.twitch.tv/app
    Usage: $SCRIPT_NAME --create my_ig instagram rtmp://live-upload.instagram.com:80/rtmp <key>

  --list [option]
    List available channels.

    Usage: $SCRIPT_NAME --list            # Show all channels
    Usage: $SCRIPT_NAME --list --ids      # Show IDs and names

  --get-id <channel_name>
    Get the database ID for a specific channel.

    Usage: $SCRIPT_NAME --get-id my_twitch

  --get <channel> <key>
    Fetch a specific value from the database for a channel.

    Parameters:
      - key: refresh_token, stream_key

    Usage: $SCRIPT_NAME --get my_twitch refresh_token

  --set <channel> <key> <value>
    Update a specific value in the database for a channel.

    Parameters:
      - key: access_token, client_id, client_secret, refresh_token, platform, stream_url, display_name, stream_key

    Usage: $SCRIPT_NAME --set my_twitch access_token abc123xyz789
    Usage: $SCRIPT_NAME --set my_ig stream_key new_instagram_key
    Usage: $SCRIPT_NAME --set my_twitch display_name \"My Main Twitch\"
    Usage: $SCRIPT_NAME --set my_youtube client_secret <google_client_secret>

  --remove <channel>
    Remove a channel. Warns if channel is linked to broadcasts.

    Usage: $SCRIPT_NAME --remove my_instagram

  --refresh-tokens <channel>
    Manually trigger token refresh (Twitch/YouTube).
    For YouTube, verifies credentials can obtain fresh tokens.

    Usage: $SCRIPT_NAME --refresh-tokens my_twitch
    Usage: $SCRIPT_NAME --refresh-tokens my_youtube

  --test-tokens <channel>
    Validate that a channel's API credentials are valid (Twitch/YouTube).

    Usage: $SCRIPT_NAME --test-tokens my_twitch
    Usage: $SCRIPT_NAME --test-tokens my_youtube

  --auto-fetch-key <channel>
    Automatically fetch and store the stream key from platform API (Twitch/YouTube).
    Requires API credentials to be configured.

    Usage: $SCRIPT_NAME --auto-fetch-key my_twitch
    Usage: $SCRIPT_NAME --auto-fetch-key my_youtube

EXAMPLES:

  # Create Twitch channel with API auto-fetch
  channelmod --create my_twitch twitch rtmp://live.twitch.tv/app
  channelmod --set my_twitch access_token <token>
  channelmod --set my_twitch client_id <client_id>
  channelmod --set my_twitch refresh_token <refresh_token>
  channelmod --auto-fetch-key my_twitch    # Fetch stream key from API

  # Or create Twitch channel with manual key
  channelmod --create my_twitch twitch rtmp://live.twitch.tv/app <stream_key>

  # Create YouTube channel with API auto-fetch
  channelmod --create my_youtube youtube rtmp://a.rtmp.youtube.com/live2
  channelmod --set my_youtube client_id <google_client_id>
  channelmod --set my_youtube client_secret <google_client_secret>
  channelmod --set my_youtube refresh_token <google_refresh_token>
  channelmod --test-tokens my_youtube      # Verify credentials
  channelmod --auto-fetch-key my_youtube   # Fetch stream key from API

  # Or create YouTube channel with manual key
  channelmod --create my_youtube youtube rtmp://a.rtmp.youtube.com/live2 <yt_key>

  # Create Instagram channel with key
  channelmod --create my_instagram instagram rtmp://live-upload.instagram.com:80/rtmp <ig_key>

  # Create Facebook channel
  channelmod --create my_facebook facebook rtmps://live-api-s.facebook.com:443/rtmp <fb_key>

  # List all channels
  channelmod --list

  # Update stream key
  channelmod --set my_instagram stream_key new_key_here

  # Test platform tokens
  channelmod --test-tokens my_twitch
  channelmod --test-tokens my_youtube

  # Refresh platform tokens
  channelmod --refresh-tokens my_twitch
  channelmod --refresh-tokens my_youtube

PLATFORM-SPECIFIC NOTES:

  Twitch:
    - OAuth2 with 60-day token expiry
    - Requires: client_id, access_token, refresh_token
    - Stream keys auto-fetched at container start if API credentials present
    - Use --auto-fetch-key to manually fetch and store key
    - Use --refresh-tokens when tokens expire

  YouTube:
    - OAuth2 with 1-hour token expiry (fetched fresh each time)
    - Requires: client_id, client_secret, refresh_token
    - access_token NOT stored (too short-lived, fetched on-demand)
    - Stream keys auto-fetched at container start
    - Must create live stream at studio.youtube.com first
    - Use --test-tokens to verify credentials

  Instagram/Facebook:
    - Manual stream key required
    - Get keys from platform's live streaming dashboard
    - Keys may expire, update with --set

WORKFLOW:
  1. Create channels with channelmod --create
  2. Create broadcasts with broadcastmod --create
  3. Link channels to broadcasts with broadcastmod --link
  4. Start streaming with containermod --broadcast <name>
"
        exit 0
    ;;

    *)
        echo "Option $OPERATION not recognised. Try '$SCRIPT_NAME --help' for more information"
        exit 1
    ;;
esac
