#!/bin/bash

source /etc/profile

OPERATION=$1

if [ -z "$OPERATION" ];
then
    echo "$(basename "$0"): try '$(basename "$0") --help' for more information"
    exit 1
fi

CONTAINER_ID=$(docker ps -aqf "name=mysql")

case $OPERATION in
    "--add")
        read -r -p "What's the technical name of the game? (eg. pubg, csgo)" NAME
        read -r -p "What's the display name of the game? (eg. Playerunknow's Battlegrounds)" DISPLAYNAME
        read -r -p "What's the abbreviation of the game? (eg. PUBG, CS:GO)" ABBR
        read -r -p "What's the delay of streams for the game in seconds?" DELAY

        echo "Creating a new game with details
        Technical name: $NAME
        Display name: $DISPLAYNAME
        Abbreviation: $ABBR
        Delay: $DELAY
        "

        read -r -p "Are you sure you want to create a new game with above details? [y/N] " RESPONSE
        case "$RESPONSE" in
            [yY][eE][sS]|[yY])
                docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "INSERT INTO games (name, display_name, abbreviation, delay) VALUES ('$NAME', '$DISPLAYNAME', '$ABBR', $DELAY)"
                ;;
            *)
                exit 0
                ;;
        esac
    ;;
    "--list")
        OPTION=$2

        if [ -z "$OPTION" ];
        then
            docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT name, delay FROM games ORDER BY name"
            exit 0
        fi

        case $OPTION in
            "--ids")
                docker exec -it $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -e "SELECT id, name FROM games ORDER BY id"
                exit 0
            ;;
            "--names")
                docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT name FROM games ORDER BY name"
                exit 0
            ;;
            *)
                OUTPUT=$(docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT name FROM games WHERE name = '$OPTION'")

                if [[ ! -z $OUTPUT ]];
                then
                    echo "$OUTPUT"
                    exit 0
                else
                    echo "[ERROR]: Game $OPTION not found from the database."
                    exit 1
                fi
            ;;
        esac
    ;;
    "--help")
        echo "$(basename "$0") -- Manage games in the MySQL database

DESCRIPTION:
  Add and list games that can be streamed to Twitch. Each game has a technical name,
  display name (must match Twitch exactly), abbreviation, and optional stream delay.

USAGE:
  $(basename $0) <operation> [parameters]

OPERATIONS:

  --add
    Interactive tool to add a new game to the database.
    Prompts for:
      - Technical name:  Short lowercase identifier (e.g., pubg, csgo, rl)
      - Display name:    Official Twitch game name (e.g., PlayerUnknown's Battlegrounds)
                         MUST match Twitch Helix API exactly for stream category to work!
      - Abbreviation:    Short form for display (e.g., PUBG, CS:GO, RL)
      - Delay:           Stream delay in seconds (0 for no delay, 480 for 8 minutes)

    Usage: $(basename $0) --add

    Example inputs:
      Technical name:   pubg
      Display name:     PlayerUnknown's Battlegrounds
      Abbreviation:     PUBG
      Delay:            480

  --list [option|game]
    List games in the database.

    Usage: $(basename $0) --list              (show all games with name and delay)
    Usage: $(basename $0) --list --ids        (show IDs and names)
    Usage: $(basename $0) --list --names      (show only technical names)
    Usage: $(basename $0) --list pubg         (show specific game)

EXAMPLES:

  # Add a new game interactively
  gamemod --add

  # List all games
  gamemod --list

  # Get only game names (useful for scripts)
  gamemod --list --names

  # Check if a specific game exists
  gamemod --list rl

  # Get game IDs for streammod
  gamemod --list --ids

GAME CONFIGURATION:

  Technical Name:
    - Lowercase, no spaces
    - Used in containermod commands
    - Used in ads folder structure (nginx-http/html/ads/img/pubg/)

  Display Name:
    - MUST match Twitch category name exactly
    - Used when setting stream category via Helix API
    - Case-sensitive and punctuation-sensitive
    - Verify at: https://www.twitch.tv/directory/category/[game-name]

  Delay:
    - In seconds (0 = no delay, 480 = 8 minutes)
    - Applies to all streams for this game
    - Used for competitive integrity (prevents stream sniping)
    - 0 delay uses direct passthrough, >0 uses internal relay with buffer

NOTES:
  - Display name must be exact match with Twitch or category won't update
  - Check Twitch directory URL to verify correct game name
  - Common games: PUBG (480s), CS:GO (120s), Rocket League (0s), Dota 2 (300s)
  - Delay affects container startup (requires internal_technical_user relay)
"
    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$(basename "$0") --help' for more information"
esac
