#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source $SOURCE_DIR/functions/functions.sh
source /etc/profile

OPERATION=$1

if [ -z "$OPERATION" ];
then
    echo "$(basename "$0"): try '$(basename "$0") --help' for more information"
    exit 1
fi

case $OPERATION in
    "--add")
        NICK=$2
        DISCORD_ID=$3
        STREAM_KEY=$4

        if [ -z "$NICK" ];
        then
            echo "[ERROR]: Caster name is not present. Try '$(basename "$0") --help' for more information"
            exit 1
        fi

        if [ -z "$DISCORD_ID" ];
        then
            echo "[ERROR]: Discord ID is not present. Try '$(basename "$0") --help' for more information"
            exit 1
        fi

        if [ -z "$STREAM_KEY" ];
        then
            STREAM_KEY=$NICK-$(hexdump -n 8 -e '4/4 "%08X" 1 "\n"' /dev/urandom |awk '{print tolower($0)}' |xargs)
            echo "Stream key for the user is: $STREAM_KEY"
        fi

        echo "$MYSQL_USER"

        mysql_exec_interactive "INSERT INTO casters (nick, stream_key, discord_id, active, internal, date_added) VALUES ('$NICK', '$STREAM_KEY', '$DISCORD_ID', false, false, NOW())"
    ;;
    "--activate")
        NICK=$2

        if [ -z "$NICK" ];
        then
            echo "[ERROR]: Caster name is not present. Try '$(basename "$0") --help' for more information"
            exit 1
        fi

        mysql_exec "UPDATE casters SET active = true WHERE nick = \"$NICK\" AND internal = false"
    ;;
    "--disable")
        NICK=$2

        if [ -z "$NICK" ];
        then
            echo "[ERROR]: Caster name is not present. Try '$(basename "$0") --help' for more information"
            exit 1
        fi

        if docker ps --format '{{.Names}}' |grep $NICK >> /dev/null;
        then
          echo "Caster has active containers, can't disable the access"
        else
          mysql_exec "UPDATE casters SET active = false WHERE nick = \"$NICK\" AND internal = false"
        fi
    ;;
    "--list")
        OPTION=$2

        if [ -z "$OPTION" ];
        then
            mysql_exec_interactive "SELECT nick, stream_key, CASE WHEN active = false THEN 'disabled' ELSE 'active' END as active, date_added FROM casters WHERE internal = false ORDER BY nick"
            exit 0
        fi

        case $OPTION in
            "--ids")
                mysql_exec_interactive "SELECT id, nick FROM casters WHERE internal = false ORDER BY id"
                exit 0
            ;;
            "--nicks")
                mysql_exec_silent "SELECT nick FROM casters WHERE internal = false ORDER BY nick"
                exit 0
            ;;
            *)
                OUTPUT=$(docker exec $CONTAINER_ID mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT nick, stream_key, CASE WHEN active = false THEN 'disabled' ELSE 'active' END as active, date_added FROM casters WHERE nick = '$OPTION' AND internal = false")

                if [[ ! -z "$OUTPUT" ]];
                then
                    echo "$OUTPUT"
                    exit 0
                else
                    echo "[ERROR]: Caster $NICK not found from the database."
                    exit 1
                fi
            ;;
        esac
    ;;
    "--remove")
        NICK=$2

        if [ -z "$NICK" ];
        then
            echo "[ERROR]: Caster name is not present. Try '$(basename "$0") --help' for more information"
            exit 1
        fi

        read -r -p "Are you sure you want to remove $NICK? [y/N] " response
        case "$response" in
            [yY][eE][sS]|[yY])
                mysql_exec_interactive "DELETE FROM casters WHERE nick = \"$NICK\" AND internal = false"
                ;;
            *)
                exit 0
                ;;
        esac
    ;;
    "--help")
        echo "$(basename "$0") -- Manage casters in the MySQL database

DESCRIPTION:
  Add, remove, activate, and list casters who can authenticate to the RTMP service.
  Each caster has a unique stream key and Discord ID for notifications.

USAGE:
  $(basename $0) <operation> [parameters]

OPERATIONS:

  --add <nick> <discord_id> [stream_key]
    Add a new caster to the database.

    Parameters:
      - nick:       Caster's nickname (e.g., JohnDoe)
      - discord_id: Caster's Discord user ID (long number, NOT nick#1234)
                    Get this from Discord Developer Mode > Right-click user > Copy User ID
      - stream_key: Optional. Auto-generated if not provided (format: nick-hexstring)

    Usage: $(basename $0) --add JohnDoe 123456788901234567
    Usage: $(basename $0) --add JohnDoe 123456788901234567 JohnDoe-abc123def456

  --activate <nick>
    Activate a caster, allowing them to authenticate to the RTMP service.
    Sets the 'active' flag to true in the database.

    Usage: $(basename $0) --activate JohnDoe

    Note: Casters are automatically activated when their container starts
          and deactivated when it stops.

  --disable <nick>
    Disable a caster, preventing authentication to the RTMP service.
    Sets the 'active' flag to false. Cannot disable if caster has active containers.

    Usage: $(basename $0) --disable JohnDoe

  --list [option|nick]
    List casters in the database.

    Usage: $(basename $0) --list              (show all casters with details)
    Usage: $(basename $0) --list --ids        (show IDs and nicks)
    Usage: $(basename $0) --list --nicks      (show only nicks)
    Usage: $(basename $0) --list JohnDoe        (show specific caster)

  --remove <nick>
    Remove a caster from the database (requires confirmation).

    Usage: $(basename $0) --remove JohnDoe

    Warning: This permanently deletes the caster. Cannot be undone.

EXAMPLES:

  # Add a new caster (auto-generates stream key)
  castermod --add JohnDoe 123456788901234567

  # Add a caster with specific stream key
  castermod --add JohnDoe 123456788901234567 JohnDoe-customkey123

  # List all casters
  castermod --list

  # Get only nicknames (useful for scripts)
  castermod --list --nicks

  # Activate a caster manually
  castermod --activate JohnDoe

  # Check specific caster details
  castermod --list JohnDoe

  # Remove a caster
  castermod --remove OldCaster

NOTES:
  - Stream keys are automatically generated in format: nick-hexstring
  - Discord IDs are used for automated notifications
  - Internal users (internal_technical_user, vlc_viewer) are excluded from most operations
  - Active status is managed automatically by containermod when containers start/stop
"
    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$(basename "$0") --help' for more information"
esac
