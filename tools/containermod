#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source "$SOURCE_DIR/functions/functions.sh"
source /etc/profile

# Configuration paths
readonly HAPROXY_CONFIG_DIR="/opt/haproxy"
readonly LETSENCRYPT_DIR="/opt/letsencrypt"
readonly MYSQL_DATA_DIR="/opt/mysql/data"
readonly LOCK_DIR="/var/lock"

# Helper functions for container management
usage() {
  SCRIPT_NAME=$SCRIPT_NAME
  echo "$SCRIPT_NAME -- Manage RTMP streaming containers

DESCRIPTION:
  Manages base infrastructure containers (mysql, php-fpm, nginx-http, haproxy) and
  per-caster stream containers (nginx-rtmp). Safety mechanisms prevent stopping
  infrastructure containers while stream containers are active.

CONTAINER TYPES:
  Base containers (required for operation):
    - mysql:      Database backend
    - php-fpm:    PHP processor for auth.php and ads.php
    - nginx-http: HTTP server for /ads/ and /rtmp/ contexts
    - haproxy:    Load balancer and traffic router

  Stream containers (per-caster, created on demand):
    - nginx-rtmp-<caster>:       Broadcast container (outputs to platform channels)
    - nginx-rtmp-proxy-<caster>: Proxy container (internal relay only)

USAGE:
  $SCRIPT_NAME <options>

COMMON OPERATIONS:
  List all running containers:
    $SCRIPT_NAME --list

  Start all base containers:
    $SCRIPT_NAME --start --all

  Restart all base containers (fails if streams active):
    $SCRIPT_NAME --restart --all

  Restart single base container:
    $SCRIPT_NAME --restart --name haproxy

  Start a broadcast container (outputs to linked channels):
    $SCRIPT_NAME --start --name nginx-rtmp --caster JohnDoe --broadcast morning-show --game pubg

  Start a proxy container:
    $SCRIPT_NAME --start --name nginx-rtmp --caster JohnDoe --broadcast johndoe-proxy --proxy

  Stop a stream container:
    $SCRIPT_NAME --stop --name nginx-rtmp --caster JohnDoe

  Stop a proxy container:
    $SCRIPT_NAME --stop --name nginx-rtmp --caster JohnDoe --proxy

OPTIONS:
  -a, --all                      Operate on all base containers (mysql, php-fpm, nginx-http, haproxy)
                                 Mutually exclusive with --name

  -C, --caster <caster>          Caster nickname (required for nginx-rtmp operations)

  -b, --broadcast <broadcast>    Broadcast name (required when starting nginx-rtmp)
                                 Broadcast outputs to all linked platform channels

  -g, --game <game>              Game name (required when starting non-proxy nginx-rtmp)

  -h, --help                     Display this help message

  -k, --key <stream_key>         Deprecated: Stream keys now stored in channel configuration

  -l, --list                     List all running containers

  -n, --name <container>         Container name: nginx-rtmp, mysql, php-fpm, nginx-http, haproxy
                                 Mutually exclusive with --all

  -p, --proxy                    Handle nginx-rtmp container as proxy-only (no platform streaming)

  -r, --restart                  Restart container(s). NOT supported for nginx-rtmp containers.
                                 Requires --name or --all

  -s, --start                    Start container(s). For nginx-rtmp requires --caster, --broadcast,
                                 and --game (unless --proxy is specified)

  -S, --stop                     Stop container(s). For nginx-rtmp requires --caster (and --proxy if applicable)

IMPORTANT NOTES:
  - nginx-http and php-fpm CANNOT be stopped while nginx-rtmp containers are running
    (safety mechanism checked via $LOCK_DIR/nginx-rtmp-*.lock files)
  - nginx-rtmp containers CANNOT use --restart (use --stop then --start instead)
  - To restart all: first stop all nginx-rtmp containers, then restart base containers
  - Broadcasts can output to multiple platforms (Twitch, Instagram, Facebook, YouTube)
  - Use broadcastmod to link channels to broadcasts

EXAMPLES:
  # Full restart procedure
  containermod --stop --name nginx-rtmp --caster JohnDoe
  containermod --stop --name nginx-rtmp --caster JohnDoe --proxy
  containermod --restart --all

  # Start streaming to broadcast (outputs to all linked channels)
  containermod --start --name nginx-rtmp --caster JohnDoe --broadcast morning-show --game csgo

  # Setup workflow
  channelmod --create my_twitch twitch rtmp://live.twitch.tv/app
  channelmod --create my_instagram instagram rtmp://live-upload.instagram.com:80/rtmp <key>
  broadcastmod --create morning-show 48001
  broadcastmod --link morning-show my_twitch
  broadcastmod --link morning-show my_instagram
  containermod --start --name nginx-rtmp --caster JohnDoe --broadcast morning-show --game csgo
"
}

check_stream_container_lock() {
    if [[ $(find "$LOCK_DIR" -maxdepth 1 -name "nginx-rtmp-*.lock") ]];
    then
        return 1
    else
        return 0
    fi
}

check_running() {
    RUNNING_CONTAINER=$1
    OLD=$(docker ps -aqf "name=$RUNNING_CONTAINER")
    if [ ! -z "$OLD" ];
    then
        return 1
    fi
}

get_image_name() {
    # Constructs full image name based on registry configuration
    # Args: $1 = image name (e.g., haproxy, mysql)
    #       $2 = version tag (e.g., v1.6)
    local IMAGE_NAME="$1"
    local VERSION="$2"

    if [ -n "$REGISTRY_URL" ]; then
        # Custom registry
        echo "$REGISTRY_URL/$IMAGE_NAME:$VERSION"
    elif [ -n "$DOCKER_USERNAME" ]; then
        # Docker Hub
        echo "$DOCKER_USERNAME/$IMAGE_NAME:$VERSION"
    else
        # Local images only
        echo "$IMAGE_NAME:latest"
    fi
}

pull_container() {
    PULLED_IMAGE_VERSION="$(echo "$1" | tr '-' '_' | tr '[:lower:]' '[:upper:]')""_VERSION"
    IMAGE_NAME=$(get_image_name "$1" "${!PULLED_IMAGE_VERSION}")

    # Only pull if using a registry (not local)
    if [ -n "$REGISTRY_URL" ] || [ -n "$DOCKER_USERNAME" ]; then
        echo "Pulling image $IMAGE_NAME"
        if ! docker pull "$IMAGE_NAME";
        then
            echo "ERROR: Failed to pull $IMAGE_NAME"
            exit 1
        fi
    else
        echo "Using local image: $IMAGE_NAME"
        # Verify local image exists
        if ! docker image inspect "$IMAGE_NAME" > /dev/null 2>&1; then
            echo "ERROR: Local image $IMAGE_NAME not found. Build it first with:"
            echo "  cd tools && ./build_all_images.sh"
            exit 1
        fi
    fi
}

# Helper functions for starting individual container types
run_haproxy_container() {
    if ! check_running "haproxy";
    then
        echo "A haproxy container is already running. If you need to restart use --restart instead."
        exit 1
    fi

    pull_container "haproxy"

    mkdir -p "$HAPROXY_CONFIG_DIR"

    HAPROXY_IMAGE=$(get_image_name "haproxy" "$HAPROXY_VERSION")

    echo "Extracting fresh HAProxy config from image..."
    docker run --rm "$HAPROXY_IMAGE" cat /usr/local/etc/haproxy/templates/haproxy.cfg > "$HAPROXY_CONFIG_DIR/haproxy.cfg"

    if [ $? -ne 0 ] || [ ! -s "$HAPROXY_CONFIG_DIR/haproxy.cfg" ];
    then
        echo "ERROR: Failed to extract HAProxy config from image"
        exit 1
    fi

    echo "HAProxy config extracted"

    docker run --rm --net stream --name haproxy -d \
    -e FQDN="$FQDN" \
    -e ADMIN_EMAIL="$ADMIN_EMAIL" \
    -v "$HAPROXY_CONFIG_DIR":/usr/local/etc/haproxy/ \
    -v "$LETSENCRYPT_DIR":/etc/letsencrypt/ \
    -p 80:80 \
    -p 443:443 \
    -p 8084:8084 \
    -p 48001-48010:48001-48010 \
    -p 48101-48110:48101-48110 \
    --sysctl net.ipv4.ip_unprivileged_port_start=0 \
    "$HAPROXY_IMAGE"
}

run_mysql_container() {
    if ! check_running "mysql";
    then
        echo "A mysql container is already running. If you need to restart use --restart instead."
        exit 1
    fi

    pull_container "mysql"

    MYSQL_IMAGE=$(get_image_name "mysql" "$MYSQL_VERSION")
    ID=$(docker run --rm --net stream --name mysql -d -v "$MYSQL_DATA_DIR":/var/lib/mysql -e MYSQL_ROOT_PASSWORD="$MYSQL_ROOT_PASSWORD" -e MYSQL_USER="$MYSQL_USER" -e MYSQL_PASSWORD="$MYSQL_PASSWORD" -e MYSQL_DATABASE="$MYSQL_DATABASE" "$MYSQL_IMAGE")
    docker exec -it "$ID" /bin/sh -c 'envsubst < /creds.cnf.template > /creds.cnf'
}

run_nginx_http_container() {
    if ! check_running "nginx-http";
    then
        echo "A nginx-http container is already running. If you need to restart use --restart instead."
        exit 1
    fi

    pull_container "nginx-http"

    NGINX_HTTP_IMAGE=$(get_image_name "nginx-http" "$NGINX_HTTP_VERSION")
    docker run --rm --net stream --name nginx-http -d \
        -e FQDN="$FQDN" \
        --add-host=host.docker.internal:host-gateway \
        "$NGINX_HTTP_IMAGE"
}

run_nginx_rtmp_container() {
    if check_running "mysql";
    then
        echo "A mysql container is not running. If you need to restart use --restart instead."
        exit 1
    fi

    STREAM_DELAY=0

    if ! search_caster "$CASTER";
    then
        exit 1
    fi

    if $PROXY;
    then
        CONTAINER_NAME="nginx-rtmp-proxy-$CASTER"
    else
        CONTAINER_NAME="nginx-rtmp-$CASTER"
    fi

    if ! check_running "$CONTAINER_NAME";
    then
        echo "A $CONTAINER_NAME container is already running. If you need to restart, use --restart instead."
        exit 1
    fi

    # Check if broadcast exists
    if ! search_broadcast "$BROADCAST";
    then
        exit 1
    fi

    BROADCAST_ID=$(mysql_exec_silent "SELECT id FROM broadcasts WHERE name = '$BROADCAST'")
    BROADCAST_ID=$(strip_cr "$BROADCAST_ID")

    if ! $PROXY;
    then
        if [ -z "$GAME" ];
        then
            echo "Game is not provided. Try '$SCRIPT_NAME --help' for more information"
            exit 1
        fi

        if ! search_game "$GAME";
        then
            exit 1
        fi

        # Get all enabled channels for this broadcast
        echo "Fetching channels for broadcast '$BROADCAST'..."

        CHANNEL_DATA=$(mysql_exec_silent "
            SELECT CONCAT(c.name, '|', c.platform, '|', c.stream_url, '|', COALESCE(c.stream_key, ''), '|', COALESCE(c.access_token, ''), '|', COALESCE(c.client_id, ''), '|', COALESCE(c.client_secret, ''), '|', COALESCE(c.refresh_token, ''))
            FROM channels c
            JOIN broadcast_channels bc ON bc.channel_id = c.id
            WHERE bc.broadcast_id = $BROADCAST_ID
            AND bc.enabled = TRUE
            ORDER BY bc.priority
        ")

        if [ -z "$CHANNEL_DATA" ];
        then
            echo "ERROR: No enabled channels found for broadcast '$BROADCAST'"
            echo "Use 'broadcastmod --link $BROADCAST <channel>' to add channels"
            exit 1
        fi

        # Build OUTPUTS variable (newline-delimited, pipe-separated fields)
        # Format: platform|stream_url|stream_key
        OUTPUTS=""
        HAS_ERROR=false

        while IFS='|' read -r CH_NAME CH_PLATFORM CH_URL CH_KEY CH_ACCESS_TOKEN CH_CLIENT_ID CH_CLIENT_SECRET CH_REFRESH_TOKEN; do
            CH_PLATFORM=$(strip_cr "$CH_PLATFORM")
            CH_KEY=$(strip_cr "$CH_KEY")
            CH_ACCESS_TOKEN=$(strip_cr "$CH_ACCESS_TOKEN")
            CH_CLIENT_ID=$(strip_cr "$CH_CLIENT_ID")
            CH_CLIENT_SECRET=$(strip_cr "$CH_CLIENT_SECRET")
            CH_REFRESH_TOKEN=$(strip_cr "$CH_REFRESH_TOKEN")

            # Auto-fetch for platforms that support API (Twitch, YouTube)
            if [[ "$CH_PLATFORM" == "twitch" || "$CH_PLATFORM" == "youtube" ]] && [ ! -z "$CH_CLIENT_ID" ];
            then
                # YouTube also needs client_secret
                if [ "$CH_PLATFORM" = "youtube" ] && [ -z "$CH_CLIENT_SECRET" ];
                then
                    echo "  - $CH_NAME ($CH_PLATFORM) - Missing client_secret"
                    if [ -z "$CH_KEY" ];
                    then
                        echo "  ERROR: No stream key for channel '$CH_NAME' ($CH_PLATFORM)"
                        echo "         Set client_secret or provide manual key: channelmod --set $CH_NAME stream_key <your_key>"
                        HAS_ERROR=true
                        continue
                    fi
                    echo "    Using stored key"
                else
                    echo "  - $CH_NAME ($CH_PLATFORM) - Fetching stream key from API..."
                    FETCHED_KEY=$(get_platform_stream_key "$CH_NAME" 2>/dev/null)

                    if [ $? -eq 0 ] && [ ! -z "$FETCHED_KEY" ] && [ "$FETCHED_KEY" != "null" ];
                    then
                        CH_KEY="$FETCHED_KEY"
                        echo "    ✓ Stream key fetched from API"

                        # Store for future reference (Twitch only - YouTube tokens are short-lived)
                        if [ "$CH_PLATFORM" = "twitch" ];
                        then
                            mysql_exec_silent "UPDATE channels SET stream_key = '$FETCHED_KEY' WHERE name = '$CH_NAME'" 2>/dev/null
                        fi
                    elif [ ! -z "$CH_KEY" ];
                    then
                        echo "    ! API fetch failed, using stored key"
                    else
                        echo "  ERROR: No stream key for channel '$CH_NAME' ($CH_PLATFORM)"
                        echo "         API fetch failed and no stored key available"
                        HAS_ERROR=true
                        continue
                    fi
                fi
            else
                # Platforms without API support or missing API credentials
                if [ -z "$CH_KEY" ];
                then
                    echo "  ERROR: No stream key for channel '$CH_NAME' ($CH_PLATFORM)"
                    if [[ "$CH_PLATFORM" == "twitch" || "$CH_PLATFORM" == "youtube" ]];
                    then
                        echo "         Either set key manually: channelmod --set $CH_NAME stream_key <your_key>"
                        echo "         Or configure API credentials and use: channelmod --auto-fetch-key $CH_NAME"
                    else
                        echo "         Set key with: channelmod --set $CH_NAME stream_key <your_key>"
                    fi
                    HAS_ERROR=true
                    continue
                fi
                echo "  - $CH_NAME ($CH_PLATFORM)"
            fi

            # Append to OUTPUTS
            if [ -z "$OUTPUTS" ];
            then
                OUTPUTS="${CH_PLATFORM}|${CH_URL}|${CH_KEY}"
            else
                OUTPUTS="${OUTPUTS}"$'\n'"${CH_PLATFORM}|${CH_URL}|${CH_KEY}"
            fi
        done <<< "$CHANNEL_DATA"

        if $HAS_ERROR;
        then
            echo ""
            echo "ERROR: Missing stream keys. Cannot start container."
            exit 1
        fi

        if [ -z "$OUTPUTS" ];
        then
            echo "ERROR: No valid channels configured"
            exit 1
        fi

        STREAM_DELAY=$(mysql_exec_silent "SELECT delay FROM games WHERE name = '$GAME'")
        STREAM_DELAY=$(strip_cr "$STREAM_DELAY")
    fi

    NGINX_RTMP_IMAGE=$(get_image_name "nginx-rtmp" "$NGINX_RTMP_VERSION")

    if [ $STREAM_DELAY -eq 0 ] && ! $PROXY;
    then
        docker run --rm --net stream --name nginx-rtmp-"$CASTER" -d \
            -e CASTER="$CASTER" \
            -e OUTPUTS="$OUTPUTS" \
            -e STREAM_DELAY="0" \
            -e PROXY_ONLY=false \
            "$NGINX_RTMP_IMAGE"
    elif $PROXY;
    then
        docker run --rm --net stream --name nginx-rtmp-proxy-"$CASTER" -d \
            -e CASTER="$CASTER" \
            -e STREAM_DELAY="0" \
            -e PROXY_ONLY=true \
            "$NGINX_RTMP_IMAGE"
    else
        INTERNAL_STREAM_KEY=$(mysql_exec_silent "SELECT stream_key FROM casters WHERE nick = 'internal_technical_user'")
        INTERNAL_STREAM_KEY=$(strip_cr "$INTERNAL_STREAM_KEY")

        docker run --rm --net stream --name nginx-rtmp-"$CASTER" -d \
            -e CASTER="$CASTER" \
            -e OUTPUTS="$OUTPUTS" \
            -e INTERNAL_STREAM_KEY="$INTERNAL_STREAM_KEY" \
            -e STREAM_DELAY="$STREAM_DELAY" \
            -e PROXY_ONLY=false \
            "$NGINX_RTMP_IMAGE"
    fi

    STARTUP_RESULT=$?

    if [ "$STARTUP_RESULT" -eq 1 ];
    then
        echo "[ERROR]: Container startup failed"
        exit 1
    fi

    touch "$LOCK_DIR/$CONTAINER_NAME.lock"
    if $PROXY;
    then
        haproxy_configmod --add "proxy-$CASTER" "$BROADCAST"
    else
        haproxy_configmod --add "$CASTER" "$BROADCAST"
    fi
    castermod --activate "$CASTER"
}

run_php_fpm_container() {
    if ! check_running "php-fpm";
    then
        echo "A php-fpm container is already running. If you need to restart use --restart instead."
        exit 1
    fi

    pull_container "php-fpm"

    PHP_FPM_IMAGE=$(get_image_name "php-fpm" "$PHP_FPM_VERSION")
    docker run --rm --net stream --name php-fpm -d -e MYSQL_USER="$MYSQL_USER" -e MYSQL_PASSWORD="$MYSQL_PASSWORD" -e MYSQL_DATABASE="$MYSQL_DATABASE" "$PHP_FPM_IMAGE"
}

run_container() {
    if [ ! -z "$1" ];
    then
        CONTAINER="$1"
    fi

    NETWORK=$(docker network ls |grep stream)
    if [ -z "$NETWORK" ];
    then
        docker network create -d bridge stream
    fi

    case $CONTAINER in
        "haproxy")
            run_haproxy_container
        ;;
        "mysql")
            run_mysql_container
        ;;
        "nginx-http")
            run_nginx_http_container
        ;;
        "nginx-rtmp")
            run_nginx_rtmp_container
        ;;
        "php-fpm")
            run_php_fpm_container
        ;;
    esac
}


stop_container() {
    if [ ! -z "$1" ];
    then
        CONTAINER="$1"
    fi

    case $CONTAINER in
        "nginx-rtmp")
            if $PROXY;
            then
                docker stop "$CONTAINER-proxy-$CASTER"
                haproxy_configmod --remove "proxy-$CASTER"
                rm "$LOCK_DIR/$CONTAINER-proxy-$CASTER.lock"
            else
                docker stop "$CONTAINER-$CASTER"
                haproxy_configmod --remove "$CASTER"
                rm "$LOCK_DIR/$CONTAINER-$CASTER.lock"
            fi
            castermod --disable "$CASTER"
        ;;
        "nginx-http"|"php-fpm"|"mysql"|"haproxy")
            if check_stream_container_lock;
            then
                docker stop "$CONTAINER"
            else
                echo "A stream container is running. Can't stop $CONTAINER at this time"
            fi
        ;;
        *)
            docker stop "$CONTAINER"
        ;;
    esac
}

ALL=false
CASTER=""
BROADCAST=""
GAME=""
NAME=""
OPERATION=""
PROXY=false

PARSED_ARGUMENTS=$(getopt -a -n containermod -o aC:b:g:hk:ln:prsS --long all,caster:,broadcast:,game:,help,key:,list,name:,proxy,restart,start,stop -- "$@")
VALID_ARGUMENTS=$?
if [ "$VALID_ARGUMENTS" != "0" ]; then
    usage
    exit 1
fi

eval set -- "$PARSED_ARGUMENTS"
while :
do
    case "$1" in
        -h | --help)
            usage
            exit 0
        ;;
        -l | --list )
            docker ps --all
            exit 0
        ;;
        -a | --all)
            ALL=true
            shift
        ;;
        -C | --caster)
            CASTER="$2"
            shift 2
        ;;
        -b | --broadcast)
            BROADCAST="$2"
            shift 2
        ;;
        -g | --game)
            GAME="$2"
            shift 2
        ;;
        -n | --name)
            CONTAINER="$2"
            shift 2
        ;;
        -p | --proxy)
            PROXY=true
            shift
        ;;
        -r | --restart)
            OPERATION="restart"
            shift
        ;;
        -s | --start)
            OPERATION="start"
            shift
        ;;
        -S | --stop)
            OPERATION="stop"
            shift
        ;;
        -k | --key)
            PREDFINED_STREAM_KEY="$2"
            shift 2
        ;;
        --)
            shift
            break
        ;;
        *)
            echo "Unexpected option: $1 - this should not happen."
            usage
            exit 1
        ;;
    esac
done

if [[ $ALL && ! -z $NAME ]];
then
    echo "ERROR: -a, --all and -n, --name can't be defined together. Try '$SCRIPT_NAME --help' for more information"
    exit 1
fi

require_operation "$OPERATION"

if [ ! -z "$BROADCAST" ];
then
    if [[ "$BROADCAST" == *-proxy ]];
    then
        PROXY=true
    fi
fi

case $OPERATION in
    "start")
        if $ALL;
        then
            run_container "mysql"
            run_container "php-fpm"
            run_container "nginx-http"
            run_container "haproxy"
        else
            if [ -z "$CONTAINER" ];
            then
                echo "ERROR: Container name is missing. Try '$SCRIPT_NAME --help' for more information"
                exit 1
            fi
            case $CONTAINER in
                "haproxy")
                    run_container
                ;;
                "mysql")
                    run_container
                ;;
                "nginx-http")
                    run_container
                ;;
                "nginx-rtmp")
                    if [ -z "$CASTER" ];
                    then
                        echo "ERROR: Caster name is missing. Try '$SCRIPT_NAME --help' for more information"
                        exit 1
                    fi
                    if [ -z "$BROADCAST" ];
                    then
                        echo "ERROR: Broadcast name is missing. Try '$SCRIPT_NAME --help' for more information"
                        exit 1
                    fi
                    if [[ ! $PROXY && -z "$GAME" ]];
                    then
                        echo "ERROR: Game name is missing. Try '$SCRIPT_NAME --help' for more information"
                        exit 1
                    fi
                    run_container
                ;;
                "php-fpm")
                    run_container
                ;;
                *)
                    echo "Container name $CONTAINER not recognized. Try '$SCRIPT_NAME --help' for more information"
                ;;
            esac
        fi
    ;;
    "stop")
        if $ALL;
        then
            stop_container "mysql"
            stop_container "php-fpm"
            stop_container "nginx-http"
            stop_container "haproxy"
        else
            if [ -z "$CONTAINER" ];
            then
                echo "ERROR: Container name is missing. Try '$SCRIPT_NAME --help' for more information"
                exit 1
            fi
            case $CONTAINER in
                "haproxy")
                    stop_container
                ;;
                "mysql")
                    stop_container
                ;;
                "nginx-http")
                    stop_container
                ;;
                "nginx-rtmp")
                    if [ -z "$CASTER" ];
                    then
                        echo "ERROR: Caster name is missing. Try '$SCRIPT_NAME --help' for more information"
                        exit 1
                    fi
                    stop_container
                ;;
                "php-fpm")
                    stop_container
                ;;
                *)
                    echo "Container name $CONTAINER not recognized. Try '$SCRIPT_NAME --help' for more information"
                ;;
            esac
        fi
    ;;
    "restart")
        if $ALL;
        then
            containermod --stop --all
            containermod --start --all
        else
            if [ -z "$CONTAINER" ];
            then
                echo "ERROR: Container name is missing. Try '$SCRIPT_NAME --help' for more information"
                exit 1
            fi
            case $CONTAINER in
                "haproxy" | "mysql" | "nginx-http" | "php-fpm")
                    containermod --stop --name "$CONTAINER"
                    containermod --start --name "$CONTAINER"
                ;;
                "nginx-rtmp")
                    echo "ERROR: nginx-rtmp containers can't be restarted automatically. Use stop/start instead."
                    exit 1
                ;;
                *)
                    echo "Container $CONTAINER not recognized. Try '$SCRIPT_NAME --help' for more information"
                ;;
            esac
        fi
    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$SCRIPT_NAME --help' for more information"
        exit 1
    ;;
esac
