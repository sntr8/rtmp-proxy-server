#!/bin/bash
SOURCE_DIR="$(dirname "$0")"

source $SOURCE_DIR/functions/functions.sh
source /etc/profile

usage() {
  echo "$(basename "$0") -- Tool to manage RTMP-proxy containers.

Usage:
$(basename "$0") <optstring> <parameter>

Examples:
Restart all containers:
$(basename "$0") -ra

Start a game container
$(basename "$0") -s -n nginx-rtmp -C <caster> -c <channel> -g <game>

Stop a proxy container
$(basename "$0") -Sp -n nginx-rtmp -C <caster>

Options
-a, -all                        used together with -r, -s, -S, mutually exclusive with -n
-C, --caster <caster name>      the name of the caster
-c, --channel <channel name>    the name of the channel
-g, --game <game name>          the name of the game
-h, --help                      display this help
-l, --list                      list running containers
-n, --name <container name>     the name of the container: rtmp-nginx, mysql, php-fpm, nginx-http and haproxy. Mutually exclusive with -a
-p, --proxy                     handle the container as proxy
-r, --restart                   restart a container, requires either -n or -a
-s, --start                     start a container, requires either -n or -a and -Ccg
-S, --stop                      stop a container, requires either -n or -a and -C, might need -p
"
}

check_stream_container_lock() {
    if [[ $(find /var/lock/ -maxdepth 1 -name "nginx-rtmp-*.lock") ]];
    then
        return 1
    else
        return 0
    fi
}

check_running() {
    RUNNING_CONTAINER=$1
    OLD=$(docker ps -aqf "name=$RUNNING_CONTAINER")
    if [ ! -z $OLD ];
    then
        return 1
    fi
}

pull_container() {
    PULLED_IMAGE_VERSION="$(echo "$1" | tr '-' '_' | tr '[:lower:]' '[:upper:]')""_VERSION"
    echo "Pulling image $1 version ${!PULLED_IMAGE_VERSION}"
    if ! docker pull registry.gitlab.com/kanaliiga/stream-rtmp/"$1:${!PULLED_IMAGE_VERSION}";
    then
        exit 1
    fi
}

run_container() {
    if [ ! -z "$1" ];
    then
        CONTAINER="$1"
    fi

    NETWORK=$(docker network ls |grep stream)
    if [ -z "$NETWORK" ];
    then
        docker network create -d bridge stream
    fi

    case $CONTAINER in
        "haproxy")
            if ! check_running "$CONTAINER";
            then
                echo "A $CONTAINER container is already running. If you need to restart use --restart instead."
                exit 1
            fi

            pull_container "$CONTAINER"

            if [ -f /opt/haproxy/haproxy.cfg ];
            then
                rm /opt/haproxy/haproxy.cfg
            fi

            SESSION_ID=$(od -x /dev/urandom | head -1 | awk '{OFS="-"; print $2$3,$4,$5,$6,$7$8$9}')
            mkdir -p /tmp/"$SESSION_ID"/
            GIT_OPTS=""
            if [ ! -z "$CONFIG_BRANCH" ];
            then
                GIT_OPTS="-b $CONFIG_BRANCH"
            fi
            git clone $GIT_OPTS https://$GIT_USER:$GIT_TOKEN@gitlab.com/kanaliiga/stream-rtmp.git /tmp/"$SESSION_ID"/
            if [ -f "/tmp/"$SESSION_ID"/haproxy/config/haproxy.cfg" ];
            then
                cp /tmp/"$SESSION_ID"/haproxy/config/haproxy.cfg /opt/haproxy/haproxy.cfg
                rm -rf /tmp/"$SESSION_ID"

                docker run --rm --net stream --name haproxy -d \
                -e FQDN="$FQDN" \
                -e ADMIN_EMAIL="$ADMIN_EMAIL" \
                -v /opt/haproxy/:/usr/local/etc/haproxy/ \
                -v /opt/letsencrypt/:/etc/letsencrypt/ \
                -p 80:80 \
                -p 443:443 \
                -p 8084:8084 \
                -p 48001-48010:48001-48010 \
                -p 48101-48110:48101-48110 \
                --sysctl net.ipv4.ip_unprivileged_port_start=0 \
                registry.gitlab.com/kanaliiga/stream-rtmp/haproxy:$HAPROXY_VERSION
            else
                echo "Git clone failed"
                exit 1
            fi
        ;;
        "mysql")
            if ! check_running "$CONTAINER";
            then
                echo "A $CONTAINER container is already running. If you need to restart use --restart instead."
                exit 1
            fi

            pull_container "$CONTAINER"

            ID=$(docker run --rm --net stream --name mysql -d -v /opt/mysql/data/:/var/lib/mysql -e MYSQL_ROOT_PASSWORD="$MYSQL_ROOT_PASSWORD" -e MYSQL_USER="$MYSQL_USER" -e MYSQL_PASSWORD="$MYSQL_PASSWORD" -e MYSQL_DATABASE="$MYSQL_DATABASE" registry.gitlab.com/kanaliiga/stream-rtmp/mysql:$MYSQL_VERSION)
            docker exec -it "$ID" /bin/sh -c 'envsubst < /creds.cnf.template > /creds.cnf'
        ;;
        "nginx-http")
            if ! check_running "$CONTAINER";
            then
                echo "A $CONTAINER container is already running. If you need to restart use --restart instead."
                exit 1
            fi

            pull_container "$CONTAINER"

            docker run --rm --net stream --name nginx-http -d --add-host=host.docker.internal:host-gateway registry.gitlab.com/kanaliiga/stream-rtmp/nginx-http:$NGINX_HTTP_VERSION
        ;;
        "nginx-rtmp")
            if check_running "mysql";
            then
                echo "A mysql container is not running. If you need to restart use --restart instead."
                exit 1
            fi

            STREAM_DELAY=0

            if ! search_caster "$CASTER";
            then
                exit 1
            fi

            if $PROXY;
            then
                CONTAINER_NAME="$CONTAINER-proxy-$CASTER"
            else
                CONTAINER_NAME="$CONTAINER-$CASTER"
            fi

            if ! check_running "$CONTAINER_NAME";
            then
                echo "A $CONTAINER_NAME container is already running. If you need to restart, use --restart instead."
                exit 1
            fi

            if ! search_channel "$CHANNEL";
            then
                exit 1
            fi

            if ! $PROXY;
            then
                if [ -z "$GAME" ];
                then
                    echo "Game is not provided. Try '$(basename "$0") --help' for more information"
                    exit 1
                fi

                if ! search_game "$GAME";
                then
                    exit 1
                fi

                MYSQL_CONTAINER_ID=$(docker ps -aqf "name=mysql")
                if [ -z $PREDFINED_STREAM_KEY ];
                then
                    echo "Fetching stream key from the Twitch API"
                    if ! TWITCH_STREAM_KEY=$(twitch_get_stream_key $CHANNEL);
                    then
                        echo "ERROR: Fetching Twitch stream key failed."
                        twitch_get_api_error $CHANNEL
                        exit 1
                    fi
                else
                    echo "Using the predefined stream key"
                    TWITCH_STREAM_KEY="$PREDFINED_STREAM_KEY"
                fi

                STREAM_DELAY=$(docker exec "$MYSQL_CONTAINER_ID" mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT delay FROM games WHERE name = '$GAME'")
                STREAM_DELAY=${STREAM_DELAY%$'\r'}
            fi

            if [ $STREAM_DELAY -eq 0 ] && ! $PROXY;
            then
                docker run --rm --net stream --name nginx-rtmp-"$CASTER" -d -e CASTER="$CASTER" -e CHANNEL="$CHANNEL" -e GAME="$GAME" -e TWITCH_STREAM_KEY="$TWITCH_STREAM_KEY" -e STREAM_DELAY="0" -e PROXY_ONLY=false registry.gitlab.com/kanaliiga/stream-rtmp/nginx-rtmp:$NGINX_RTMP_VERSION
            elif $PROXY;
            then
                docker run --rm --net stream --name nginx-rtmp-proxy-"$CASTER" -d -e CASTER="$CASTER" -e STREAM_DELAY="0" -e PROXY_ONLY=true registry.gitlab.com/kanaliiga/stream-rtmp/nginx-rtmp:$NGINX_RTMP_VERSION
            else
                INTERNAL_STREAM_KEY=$(docker exec "$MYSQL_CONTAINER_ID" mysql --defaults-extra-file=/creds.cnf -sN -e "SELECT stream_key FROM casters WHERE nick = 'internal_technical_user'")
                INTERNAL_STREAM_KEY=${INTERNAL_STREAM_KEY%$'\r'}

                docker run --rm --net stream --name nginx-rtmp-"$CASTER" -d -e CASTER="$CASTER" -e CHANNEL="$CHANNEL" -e GAME="$GAME" -e TWITCH_STREAM_KEY="$TWITCH_STREAM_KEY" -e INTERNAL_STREAM_KEY="$INTERNAL_STREAM_KEY" -e STREAM_DELAY="$STREAM_DELAY" -e PROXY_ONLY=false registry.gitlab.com/kanaliiga/stream-rtmp/nginx-rtmp:$NGINX_RTMP_VERSION
            fi

            STARTUP_RESULT=$?

            if [ "$STARTUP_RESULT" -eq 1 ];
            then
                echo "[ERROR]: Container startup failed"
                exit 1
            fi

            touch /var/lock/"$CONTAINER_NAME".lock
            if $PROXY;
            then
                haproxy_configmod --add "proxy-$CASTER" "$CHANNEL"
            else
                haproxy_configmod --add "$CASTER" "$CHANNEL"
            fi
            castermod --activate "$CASTER"
        ;;
        "php-fpm")
            if ! check_running "$CONTAINER";
            then
                echo "A $CONTAINER container is already running. If you need to restart use --restart instead."
                exit 1
            fi

            pull_container "$CONTAINER"

            docker run --rm --net stream --name php-fpm -d -e MYSQL_USER="$MYSQL_USER" -e MYSQL_PASSWORD="$MYSQL_PASSWORD" -e MYSQL_DATABASE="$MYSQL_DATABASE" registry.gitlab.com/kanaliiga/stream-rtmp/php-fpm:$PHP_FPM_VERSION
        ;;
    esac
}


stop_container() {
    if [ ! -z "$1" ];
    then
        CONTAINER="$1"
    fi

    case $CONTAINER in
        "nginx-rtmp")
            if $PROXY;
            then
                docker stop "$CONTAINER-proxy-$CASTER"
                haproxy_configmod --remove "proxy-$CASTER"
                rm /var/lock/"$CONTAINER-proxy-$CASTER".lock
            else
                docker stop "$CONTAINER-$CASTER"
                haproxy_configmod --remove "$CASTER"
                rm /var/lock/"$CONTAINER-$CASTER".lock
            fi
            castermod --disable "$CASTER"
        ;;
        "nginx-http"|"php-fpm")
            if check_stream_container_lock;
            then
                docker stop "$CONTAINER"
            else
                echo "A stream container is running. Can't stop $CONTAINER at this time"
            fi
        ;;
        *)
            docker stop "$CONTAINER"
        ;;
    esac
}

ALL=false
CASTER=""
CHANNEL=""
GAME=""
NAME=""
OPERATION=""
PROXY=false

PARSED_ARGUMENTS=$(getopt -a -n containermod -o aC:c:g:hk:ln:prsS --long all,caster:,channel:,game:,help,key:,list,name:,proxy,restart,start,stop -- "$@")
VALID_ARGUMENTS=$?
if [ "$VALID_ARGUMENTS" != "0" ]; then
    usage
    exit 1
fi

eval set -- "$PARSED_ARGUMENTS"
while :
do
    case "$1" in
        -h | --help)
            usage
            exit 0
        ;;
        -l | --list )
            docker ps --all
            exit 0
        ;;
        -a | --all)
            ALL=true
            shift
        ;;
        -C | --caster)
            CASTER="$2"
            shift 2
        ;;
        -c | --channel)
            CHANNEL="$2"
            shift 2
        ;;
        -g | --game)
            GAME="$2"
            shift 2
        ;;
        -n | --name)
            CONTAINER="$2"
            shift 2
        ;;
        -p | --proxy)
            PROXY=true
            shift
        ;;
        -r | --restart)
            OPERATION="restart"
            shift
        ;;
        -s | --start)
            OPERATION="start"
            shift
        ;;
        -S | --stop)
            OPERATION="stop"
            shift
        ;;
        -k | --key)
            PREDFINED_STREAM_KEY="$2"
            shift 2
        ;;
        --)
            shift
            break
        ;;
        *)
            echo "Unexpected option: $1 - this should not happen."
            usage
            exit 1
        ;;
    esac
done

if [[ $ALL && ! -z $NAME ]];
then
    echo "ERROR: -a, --all and -n, --name can't be defined together. Try '$(basename "$0") --help' for more information"
    exit 1
fi

if [ -z "$OPERATION" ];
then
    echo "ERROR: Operation was missing. Try '$(basename "$0") --help' for more information"
    exit 1
fi

if [ ! -z $CHANNEL ];
then
    if [[ "$CHANNEL" == *-proxy ]];
    then
        PROXY=true
    fi
fi

CONTAINER_ID=$(docker ps -aqf "name=mysql")

case $OPERATION in
    "start")
        if $ALL;
        then
            run_container "mysql"
            run_container "php-fpm"
            run_container "nginx-http"
            run_container "haproxy"
        else
            if [ -z "$CONTAINER" ];
            then
                echo "ERROR: Container name is missing. Try '$(basename "$0") --help' for more information"
                exit 1
            fi
            case $CONTAINER in
                "haproxy")
                    run_container
                ;;
                "mysql")
                    run_container
                ;;
                "nginx-http")
                    run_container
                ;;
                "nginx-rtmp")
                    if [ -z "$CASTER" ];
                    then
                        echo "ERROR: Caster name is missing. Try '$(basename "$0") --help' for more information"
                        exit 1
                    fi
                    if [ -z "$CHANNEL" ];
                    then
                        echo "ERROR: Channel name is missing. Try '$(basename "$0") --help' for more information"
                        exit 1
                    fi
                    if [[ ! $PROXY && -z "$GAME" ]];
                    then
                        echo "ERROR: Game name is missing. Try '$(basename "$0") --help' for more information"
                        exit 1
                    fi
                    run_container
                ;;
                "php-fpm")
                    run_container
                ;;
                *)
                    echo "Container name $CONTAINER not recognized. Try '$(basename "$0") --help' for more information"
                ;;
            esac
        fi
    ;;
    "stop")
        if $ALL;
        then
            stop_container "mysql"
            stop_container "php-fpm"
            stop_container "nginx-http"
            stop_container "haproxy"
        else
            if [ -z "$CONTAINER" ];
            then
                echo "ERROR: Container name is missing. Try '$(basename "$0") --help' for more information"
                exit 1
            fi
            case $CONTAINER in
                "haproxy")
                    stop_container
                ;;
                "mysql")
                    stop_container
                ;;
                "nginx-http")
                    stop_container
                ;;
                "nginx-rtmp")
                    if [ -z "$CASTER" ];
                    then
                        echo "ERROR: Caster name is missing. Try '$(basename "$0") --help' for more information"
                        exit 1
                    fi
                    stop_container
                ;;
                "php-fpm")
                    stop_container
                ;;
                *)
                    echo "Container name $CONTAINER not recognized. Try '$(basename "$0") --help' for more information"
                ;;
            esac
        fi
    ;;
    "restart")
        if $ALL;
        then
            containermod --stop --all
            containermod --start --all
        else
            if [ -z "$CONTAINER" ];
            then
                echo "ERROR: Container name is missing. Try '$(basename "$0") --help' for more information"
                exit 1
            fi
            case $CONTAINER in
                "haproxy" | "mysql" | "nginx-http" | "php-fpm")
                    containermod --stop --name "$CONTAINER"
                    containermod --start --name "$CONTAINER"
                ;;
                "nginx-rtmp")
                    echo "ERROR: nginx-rtmp containers can't be restarted automatically. Use stop/start instead."
                    exit 1
                ;;
                *)
                    echo "Container $CONTAINER not recognized. Try '$(basename "$0") --help' for more information"
                ;;
            esac
        fi
    ;;
    *)
        echo "Option $OPERATION not recognised. Try '$(basename "$0") --help' for more information"
    ;;
esac
